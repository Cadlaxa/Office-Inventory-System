<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Office_Supplies_Inventory"
        x:DataType="vm:MainViewModel"
        x:Class="Office_Supplies_Inventory.MainWindow"
        Title="Office Supplies Inventory System" Width="1150" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource SystemControlPageBackgroundChromeLowBrush}">

    <Window.Styles>
        <!-- Material You Card Style with Soft Shadow -->
        <Style Selector="Border.MaterialCard">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"/>
            <Setter Property="BoxShadow" Value="0 4 12 0 #15000000"/>
        </Style>

        <!-- Material You Button Base (Pill Shaped + Animations) -->
        <Style Selector="Button.MaterialBtn">
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="RenderTransform" Value="scale(1.0)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <!-- Smooth scaling and color fading, removed BoxShadow transition -->
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" Easing="QuadraticEaseOut"/>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- Button Hover and Press Animations -->
        <Style Selector="Button.MaterialBtn:pointerover">
            <!-- Smoothly enlarge on hover -->
            <Setter Property="RenderTransform" Value="scale(1.03)"/>
        </Style>
        <Style Selector="Button.MaterialBtn:pressed">
            <!-- Smoothly shrink when clicked -->
            <Setter Property="RenderTransform" Value="scale(0.96)"/>
        </Style>

        <!-- Google Material Accent Colors with Hover States -->
        <Style Selector="Button.Primary">
            <Setter Property="Background" Value="#1A73E8"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.Primary:pointerover">
            <Setter Property="Background" Value="#1557B0"/>
        </Style>

        <Style Selector="Button.Success">
            <Setter Property="Background" Value="#1E8E3E"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.Success:pointerover">
            <Setter Property="Background" Value="#145C26"/>
        </Style>

        <Style Selector="Button.Danger">
            <Setter Property="Background" Value="#D93025"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.Danger:pointerover">
            <Setter Property="Background" Value="#A51F16"/>
        </Style>

        <Style Selector="Button.Secondary">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Style>
        <Style Selector="Button.Secondary:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseMediumLowBrush}"/>
        </Style>

        <!-- Material You TextBox -->
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeLowBrush}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#1A73E8"/>
        </Style>
        
        <!-- Subtle Section Headers -->
        <Style Selector="TextBlock.SectionHeader">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>

        <!-- DataGrid Row Hover Animation -->
        <Style Selector="DataGridRow">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="DataGridRow:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}"/>
        </Style>
    </Window.Styles>

    <Panel>
        <!-- GLOBAL SEARCH BAR (Floating Top Right) -->
        <TextBox Text="{Binding SearchQuery}" 
                 Watermark="🔍 Search records..." 
                 Width="320"
                 HorizontalAlignment="Right" 
                 VerticalAlignment="Top"
                 Margin="0,20,20,0" 
                 FontSize="14"
                 Padding="16,8"
                 ZIndex="50"
                 Background="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
                 
        <TabControl Margin="10">
            <!-- INVENTORY TAB -->
            <TabItem Header="📦 Supplies Inventory" FontSize="16" FontWeight="SemiBold">
                <Grid ColumnDefinitions="*, 280" Margin="0,15,0,0">
                    
                    <!-- Rounded Container for DataGrid -->
                    <Border Grid.Column="0" Classes="MaterialCard" Margin="0,0,15,0" Padding="0" ClipToBounds="True">
                        
                        <DataGrid x:Name="InventoryGrid"
                                  ItemsSource="{Binding InventoryList}" 
                                  SelectedItem="{Binding SelectedItem}"
                                  SelectionMode="Extended"
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="False" 
                                  CellEditEnded="InventoryGrid_CellEditEnded"
                                  x:CompileBindings="False" 
                                  CanUserSortColumns="False" 
                                  CanUserResizeColumns="True"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="Transparent">
                            
                            <DataGrid.Styles>
                                <Style Selector="DataGridCell">
                                    <Setter Property="FontSize" Value="13" />
                                    <Setter Property="Padding" Value="12,10" />
                                </Style>
                                <Style Selector="DataGridColumnHeader">
                                    <Setter Property="FontSize" Value="13" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="Padding" Value="12,12" />
                                    <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                </Style>
                            </DataGrid.Styles>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ITEM CODE" Binding="{Binding ItemCode}" FontWeight="Bold"/>
                                <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding Description}"/>
                                <DataGridTextColumn Header="MANUFACTURER" Binding="{Binding ManufacturerSupplier}" />
                                <DataGridTextColumn Header="AS OF" Binding="{Binding AsOfDate}" />
                                <DataGridTextColumn Header="IN STOCK" Binding="{Binding InitialStock}" />
                                <DataGridTextColumn Header="IN" Binding="{Binding Stock_In}" />
                                <DataGridTextColumn Header="OUT" Binding="{Binding Stock_Out}" />
                                <DataGridTextColumn Header="FINAL" Binding="{Binding Final_Stock}" FontWeight="Bold"/>
                                <DataGridTextColumn Header="LOCATION" Binding="{Binding Location}" />
                                <DataGridTextColumn Header="REMARKS" Binding="{Binding Remarks}" />
                                <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Sidebar Actions (Material Card) -->
                    <Border Grid.Column="1" Classes="MaterialCard">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Inventory Actions" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                            
                            <TextBlock Text="Transactions" Classes="SectionHeader"/>
                            <Button Content="📥 Add Delivery (In)" Classes="MaterialBtn Success" Command="{Binding OpenStockInDialogCommand}"/>
                            <Button Content="📤 Log Request (Out)" Classes="MaterialBtn Primary" Command="{Binding OpenStockOutDialogCommand}"/>
                            
                            <Separator Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" Height="1" Margin="0,10"/>

                            <TextBlock Text="Manage Database" Classes="SectionHeader"/>
                            <Button Content="➕ Add New Item" Classes="MaterialBtn Secondary" Command="{Binding OpenAddDialogCommand}"/>
                            <Button Content="🗑️ Delete Selected" Classes="MaterialBtn Danger" 
                                    Command="{Binding DeleteSelectedItemsCommand}" 
                                    CommandParameter="{Binding #InventoryGrid.SelectedItems}"/>
                            
                            <Separator Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" Height="1" Margin="0,10"/>

                            <TextBlock Text="System Utilities" Classes="SectionHeader"/>
                                <Grid ColumnDefinitions="*,*">
                                    <Button Grid.Column="0" Content="📥 Import" 
                                            Classes="MaterialBtn Secondary" 
                                            Command="{Binding ImportDataCommand}"
                                            Margin="0,0,5,0"/>
                                            
                                    <Button Grid.Column="1" Content="📤 Export" 
                                            Classes="MaterialBtn Secondary" 
                                            Command="{Binding ExportDataCommand}"
                                            Margin="5,0,0,0"/>
                                </Grid>

                            <TextBlock Text="Appearance" Classes="SectionHeader" Margin="0,15,0,0"/>
                            <ToggleSwitch x:Name="ThemeToggle" 
                                        OffContent="Light Mode" OnContent="Dark Mode" 
                                        IsChecked="False"
                                        Checked="ThemeToggle_Toggled" Unchecked="ThemeToggle_Toggled"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- TRANSACTION LOG TAB -->
            <TabItem Header="📋 Stock In/Out Log" FontSize="16" FontWeight="SemiBold">
                <Grid RowDefinitions="Auto, *">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,15,0,15">
                        <Button Content="🗑️ Delete Selected Logs" 
                                Classes="MaterialBtn Danger"
                                HorizontalAlignment="Left" Width="220"
                                Command="{Binding DeleteSelectedLogsCommand}" 
                                CommandParameter="{Binding #TransactionLogGrid.SelectedItems}"/>
                    </StackPanel>

                    <Border Grid.Row="1" Classes="MaterialCard" Padding="0" ClipToBounds="True">
                        <DataGrid x:Name="TransactionLogGrid"
                                  ItemsSource="{Binding TransactionLogs}"
                                  SelectionMode="Extended"
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="False" 
                                  CellEditEnded="TransactionLogGrid_CellEditEnded"
                                  x:CompileBindings="False" 
                                  CanUserSortColumns="False" 
                                  CanUserResizeColumns="True"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="Transparent">

                            <DataGrid.Styles>
                                <Style Selector="DataGridCell">
                                    <Setter Property="FontSize" Value="13" />
                                    <Setter Property="Padding" Value="12,10" />
                                </Style>
                                <Style Selector="DataGridColumnHeader">
                                    <Setter Property="FontSize" Value="13" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="Padding" Value="12,12" />
                                    <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                </Style>
                            </DataGrid.Styles>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="DATE" Binding="{Binding Date}" />
                                <DataGridTextColumn Header="NAME REQUESTED" Binding="{Binding NameRequested}" />
                                <DataGridTextColumn Header="ITEM DESCRIPTION" Binding="{Binding ItemDescription}" Width="*" />
                                <DataGridTextColumn Header="QTY" Binding="{Binding Quantity}" />
                                <DataGridTextColumn Header="IN/OUT" Binding="{Binding TransactionType}" FontWeight="Bold" />
                                <DataGridTextColumn Header="CODE / ITEM NO." Binding="{Binding ItemCode}" />
                                <DataGridTextColumn Header="REMARKS" Binding="{Binding Remarks}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- DIALOG OVERLAYS -->
        <!-- Add Item Dialog -->
        <Grid Background="#B2000000" IsVisible="{Binding IsAddDialogVisible}" ZIndex="100">
            <Border Classes="MaterialCard" Width="480" CornerRadius="24" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="0 12 32 0 #40000000">
                <StackPanel Spacing="12">
                    <TextBlock Text="Add New Supply Item" FontWeight="Bold" FontSize="22" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Item (Identifier/Code):" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding NewItemForm.ItemCode}" Watermark="e.g., 44122011-FO-T04"/>
                    
                    <TextBlock Text="Item Description:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding NewItemForm.Description}" Watermark="e.g., Bond Paper (A4)"/>

                    <TextBlock Text="Manufacturer / Supplier:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding NewItemForm.ManufacturerSupplier}" Watermark="e.g., DBM PS"/>
                    
                    <Grid ColumnDefinitions="*, *" Margin="0,5,0,0">
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Initial Stock Level:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            <TextBox Text="{Binding NewItemForm.InitialStock}" Watermark="e.g., 50"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Storage Location:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            <TextBox Text="{Binding NewItemForm.Location}" Watermark="e.g., Steel Cabinet"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Remarks:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding NewItemForm.Remarks}" Watermark="Optional notes..."/>

                    <Grid ColumnDefinitions="*, *" Margin="0,20,0,0">
                        <Button Grid.Column="0" Content="Cancel" Classes="MaterialBtn Secondary" Command="{Binding CloseAddDialogCommand}" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="💾 Save Item" Classes="MaterialBtn Primary" Command="{Binding SaveNewItemCommand}" Margin="8,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Stock Out Dialog -->
        <Grid Background="#B2000000" IsVisible="{Binding IsStockOutDialogVisible}" ZIndex="100">
            <Border Classes="MaterialCard" Width="420" CornerRadius="24" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="0 12 32 0 #40000000">
                <StackPanel Spacing="12">
                    <TextBlock Text="Log Supply Request (Out)" FontWeight="Bold" FontSize="22" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Item (Code):" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding StockOutForm.ItemCode}" IsReadOnly="True" />
                    
                    <TextBlock Text="Employee Name:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding StockOutForm.NameRequested}" Watermark="e.g., Juan Dela Cruz"/>
                    
                    <TextBlock Text="Quantity:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding StockOutForm.Quantity}" Watermark="e.g., 1"/>

                    <TextBlock Text="Remarks:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding StockOutForm.Remarks}" Watermark="e.g., Received by employee"/>

                    <Grid ColumnDefinitions="*, *" Margin="0,20,0,0">
                        <Button Grid.Column="0" Content="Cancel" Classes="MaterialBtn Secondary" Command="{Binding CloseStockOutDialogCommand}" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="💾 Log Request" Classes="MaterialBtn Primary" Command="{Binding SaveStockOutCommand}" Margin="8,0,0,0" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Stock In Dialog -->
        <Grid Background="#B2000000" IsVisible="{Binding IsStockInDialogVisible}" ZIndex="100">
            <Border Classes="MaterialCard" Width="420" CornerRadius="24" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="0 12 32 0 #40000000">
                <StackPanel Spacing="12">
                    <TextBlock Text="Add Delivery (Stock In)" FontWeight="Bold" FontSize="22" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Select Item (Code):" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <ComboBox ItemsSource="{Binding AllInventoryItems}" 
                            SelectedItem="{Binding StockOutForm.Item}" 
                            HorizontalAlignment="Stretch" CornerRadius="12">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ItemCode}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    
                    <TextBlock Text="Supplier/Source:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding StockInForm.NameRequested}" Watermark="e.g., Office Depot"/>
                    
                    <TextBlock Text="Quantity Received:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding StockInForm.Quantity}" Watermark="e.g., 10"/>

                    <TextBlock Text="Remarks:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding StockInForm.Remarks}" Watermark="e.g., Monthly restocking"/>

                    <Grid ColumnDefinitions="*, *" Margin="0,20,0,0">
                        <Button Grid.Column="0" Content="Cancel" Classes="MaterialBtn Secondary" Command="{Binding CloseStockInDialogCommand}" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="💾 Add Delivery" Classes="MaterialBtn Success" Command="{Binding SaveStockInCommand}" Margin="8,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- SNACKBAR NOTIFICATION (Bottom Left) -->
        <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Margin="24,24,24,32" Padding="16,12" CornerRadius="8"
                Background="{Binding SnackbarColor}"
                IsHitTestVisible="False"
                BoxShadow="0 6 16 0 #40000000"
                Opacity="{Binding SnackbarOpacity}"
                ZIndex="200">
            <Border.Transitions>
                <Transitions>
                    <!-- Smooth fade in and out -->
                    <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="QuadraticEaseOut"/>
                </Transitions>
            </Border.Transitions>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="i" FontFamily="Consolas" FontWeight="Bold" Foreground="White" 
                           Background="#40FFFFFF" Padding="6,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding SnackbarMessage}" Foreground="White" 
                           FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Panel>
</Window>