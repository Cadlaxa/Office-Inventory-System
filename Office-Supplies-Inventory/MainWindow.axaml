<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Office_Supplies_Inventory"
        x:DataType="vm:MainViewModel"
        x:Class="Office_Supplies_Inventory.MainWindow"
        Title="Office Supplies Inventory System" Width="1150" Height="700"
        WindowStartupLocation="CenterScreen">

    <Panel>
        
        <TabControl Margin="10">
            <TabItem Header="📦 Supplies Inventory" FontSize="16" FontWeight="SemiBold">
                <Grid ColumnDefinitions="*, 250" Margin="0,15,0,0">
                    
                    <DataGrid x:Name="InventoryGrid"
                                Grid.Column="0" 
                                ItemsSource="{Binding InventoryList}" 
                                SelectedItem="{Binding SelectedItem}"
                                SelectionMode="Extended"
                                AutoGenerateColumns="False" 
                                IsReadOnly="False" 
                                CellEditEnded="InventoryGrid_CellEditEnded"
                                
                                x:CompileBindings="False" 
                                CanUserSortColumns="False" 
                                CanUserResizeColumns="True"
                                
                                GridLinesVisibility="All"
                                BorderThickness="1" 
                                BorderBrush="#D3D3D3"
                                Margin="0,0,10,0">
                        
                        <DataGrid.Styles>
                            <Style Selector="DataGridCell">
                                <Setter Property="FontSize" Value="12" />
                            </Style>
                            
                            <Style Selector="DataGridColumnHeader">
                                <Setter Property="FontSize" Value="13" />
                                <Setter Property="FontWeight" Value="Bold" />
                            </Style>
                        </DataGrid.Styles>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ITEM CODE" Binding="{Binding ItemCode}" FontWeight="Bold"/>
                            <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding Description}"/>
                            <DataGridTextColumn Header="MANUFACTURER / SUPPLIER" Binding="{Binding ManufacturerSupplier}" />
                            <DataGridTextColumn Header="AS OF" Binding="{Binding AsOfDate}" />
                            <DataGridTextColumn Header="INITIAL STOCK" Binding="{Binding InitialStock}" />
                            <DataGridTextColumn Header="IN" Binding="{Binding StockIn}" />
                            <DataGridTextColumn Header="OUT" Binding="{Binding StockOut}" />
                            <DataGridTextColumn Header="FINAL STOCK" Binding="{Binding FinalStock}" FontWeight="Bold"/>
                            <DataGridTextColumn Header="LOCATION" Binding="{Binding Location}" />
                            <DataGridTextColumn Header="REMARKS" Binding="{Binding Remarks}" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Column="1" Background="{DynamicResource SystemControlBackgroundAltHighBrush}" Padding="20" CornerRadius="8" BorderThickness="1" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
                        <StackPanel Spacing="15">
                            <TextBlock Text="Inventory Actions" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            
                            <TextBlock Text="Transactions" FontWeight="SemiBold" FontSize="14" Foreground="#555555"/>
                            <Button Content="📥 Add Delivery (Stock In)" 
                                Command="{Binding OpenStockInDialogCommand}" 
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="10"/>

                            <Button Content="📤 Log Request (Stock Out)" 
                                Command="{Binding OpenStockOutDialogCommand}" 
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="10"/>
                            
                            <Separator Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Height="1" Margin="0,5"/>

                            <TextBlock Text="Manage Database" FontWeight="SemiBold" FontSize="14" Foreground="#555555"/>
                            <Button Content="➕ Add New Item" Command="{Binding OpenAddDialogCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="10"/>
                            <Button Content="🗑️ Delete Selected Items" 
                                    Command="{Binding DeleteSelectedItemsCommand}" 
                                    CommandParameter="{Binding #InventoryGrid.SelectedItems}" 
                                    Foreground="#D32F2F" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="10"/>
                            
                            <Separator Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Height="1" Margin="0,5"/>

                            <TextBlock Text="System Utilities" FontWeight="SemiBold" FontSize="14" Foreground="#555555"/>
                            
                            <Button Content="📊 Import from CSV" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="10" Background="#2E7D32" Foreground="White" FontWeight="Bold"/>
                            <Button Content="📊 Export to CSV" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="10" Background="#2E7D32" Foreground="White" FontWeight="Bold"/>

                            <TextBlock Text="Appearance" FontWeight="SemiBold" FontSize="14" Foreground="#555555"/>
                            <ToggleSwitch x:Name="ThemeToggle" 
                                        OffContent="Light Mode" OnContent="Dark Mode" 
                                        IsChecked="True"
                                        Checked="ThemeToggle_Toggled" Unchecked="ThemeToggle_Toggled"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="📋 Stock In/Out Log" FontSize="16" FontWeight="SemiBold">
                <Grid RowDefinitions="Auto, *">
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,15,0,0">
                        <Button Content="🗑️ Delete Selected Logs" 
                                Command="{Binding DeleteSelectedLogsCommand}" 
                                CommandParameter="{Binding #TransactionLogGrid.SelectedItems}" 
                                Foreground="#D32F2F" FontWeight="Bold" Padding="10"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" 
                              x:Name="TransactionLogGrid"
                              ItemsSource="{Binding TransactionLogs}"
                              SelectionMode="Extended"
                              AutoGenerateColumns="False" 
                              IsReadOnly="False" 
                              CellEditEnded="TransactionLogGrid_CellEditEnded"
                              x:CompileBindings="False" 
                              CanUserSortColumns="False" 
                              CanUserResizeColumns="True"
                              GridLinesVisibility="All"
                              BorderThickness="1" 
                              BorderBrush="#D3D3D3"
                              Margin="0,15,0,0">

                        <DataGrid.Styles>
                            <Style Selector="DataGridCell">
                                <Setter Property="FontSize" Value="12" />
                            </Style>
                            
                            <Style Selector="DataGridColumnHeader">
                                <Setter Property="FontSize" Value="13" />
                                <Setter Property="FontWeight" Value="Bold" />
                            </Style>
                        </DataGrid.Styles>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="DATE" Binding="{Binding Date}" />
                            <DataGridTextColumn Header="NAME REQUESTED" Binding="{Binding NameRequested}" />
                            <DataGridTextColumn Header="ITEM DESCRIPTION" Binding="{Binding ItemDescription}" Width="*" />
                            <DataGridTextColumn Header="QTY" Binding="{Binding Quantity}" />
                            <DataGridTextColumn Header="IN/OUT" Binding="{Binding TransactionType}" FontWeight="Bold" />
                            <DataGridTextColumn Header="CODE / ITEM NO." Binding="{Binding ItemCode}" />
                            <DataGridTextColumn Header="REMARKS" Binding="{Binding Remarks}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            
        </TabControl>

        <Grid Background="{DynamicResource SystemControlBackgroundAltHighBrush}" IsVisible="{Binding IsAddDialogVisible}" ZIndex="100">
            <Border Background="White" Width="450" Padding="25" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="12">
                    <TextBlock Text="Add New Supply Item" FontWeight="Bold" FontSize="20" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Item (Identifier/Code):" FontSize="12" Foreground="Gray"/>
                    <TextBox Text="{Binding NewItemForm.ItemCode}" Watermark="e.g., 44122011-FO-T04"/>
                    
                    <TextBlock Text="Item Description:" FontSize="12" Foreground="Gray"/>
                    <TextBox Text="{Binding NewItemForm.Description}" Watermark="e.g., Bond Paper (A4)"/>

                    <TextBlock Text="Manufacturer / Supplier:" FontSize="12" Foreground="Gray"/>
                    <TextBox Text="{Binding NewItemForm.ManufacturerSupplier}" Watermark="e.g., DBM PS"/>
                    
                    <Grid ColumnDefinitions="*, *" Margin="0,5,0,0">
                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="Initial Stock Level:" FontSize="12" Foreground="Gray"/>
                            <TextBox Text="{Binding NewItemForm.InitialStock}" Watermark="e.g., 50"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <TextBlock Text="Storage Location:" FontSize="12" Foreground="Gray"/>
                            <TextBox Text="{Binding NewItemForm.Location}" Watermark="e.g., Steel Cabinet"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Remarks:" FontSize="12" Foreground="Gray"/>
                    <TextBox Text="{Binding NewItemForm.Remarks}" Watermark="Optional notes..."/>

                    <Grid ColumnDefinitions="*, *" Margin="0,20,0,0">
                        <Button Grid.Column="0" Content="Cancel" Command="{Binding CloseAddDialogCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,5,0"/>
                        <Button Grid.Column="1" Content="💾 Save Item" Command="{Binding SaveNewItemCommand}" Background="#2E7D32" Foreground="White" FontWeight="Bold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="5,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Background="{DynamicResource SystemRegionBrush}" IsVisible="{Binding IsStockOutDialogVisible}" ZIndex="100">
            <Border Background="White" Width="400" Padding="25" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="12">
                    <TextBlock Text="Log Supply Request (Stock Out)" FontWeight="Bold" FontSize="18" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Item (Code):" FontSize="12" Foreground="Gray"/>
                    <TextBox Text="{Binding StockOutForm.ItemCode}" IsReadOnly="True" Background="#F5F5F5"/>
                    
                    <TextBlock Text="Employee Name:" FontSize="12" Foreground="Gray"/>
                    <TextBox Text="{Binding StockOutForm.NameRequested}" Watermark="e.g., Juan Dela Cruz"/>
                    
                    <TextBlock Text="Quantity:" FontSize="12" Foreground="Gray"/>
                    <TextBox Text="{Binding StockOutForm.Quantity}" Watermark="e.g., 1"/>

                    <TextBlock Text="Remarks:" FontSize="12" Foreground="Gray"/>
                    <TextBox Text="{Binding StockOutForm.Remarks}" Watermark="e.g., Received by employee"/>

                    <Grid ColumnDefinitions="*, *" Margin="0,20,0,0">
                        <Button Grid.Column="0" Content="Cancel" Command="{Binding CloseStockOutDialogCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,5,0"/>
                        <Button Grid.Column="1" Content="💾 Log Request" Command="{Binding SaveStockOutCommand}" Background="#1976D2" Foreground="White" FontWeight="Bold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="5,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Background="{DynamicResource SystemRegionBrush}" IsVisible="{Binding IsStockInDialogVisible}" ZIndex="100">
            <Border Background="White" Width="400" Padding="25" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="12">
                    <TextBlock Text="Add Delivery (Stock In)" FontWeight="Bold" FontSize="18" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Select Item (Code):" FontSize="12" Foreground="Gray"/>
                    <ComboBox ItemsSource="{Binding AllInventoryItems}" 
                            SelectedItem="{Binding StockOutForm.Item}" 
                            HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ItemCode}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    
                    <TextBlock Text="Supplier/Source:" FontSize="12" Foreground="Gray"/>
                    <TextBox Text="{Binding StockInForm.NameRequested}" Watermark="e.g., Office Depot"/>
                    
                    <TextBlock Text="Quantity Received:" FontSize="12" Foreground="Gray"/>
                    <TextBox Text="{Binding StockInForm.Quantity}" Watermark="e.g., 10"/>

                    <TextBlock Text="Remarks:" FontSize="12" Foreground="Gray"/>
                    <TextBox Text="{Binding StockInForm.Remarks}" Watermark="e.g., Monthly restocking"/>

                    <Grid ColumnDefinitions="*, *" Margin="0,20,0,0">
                        <Button Grid.Column="0" Content="Cancel" Command="{Binding CloseStockInDialogCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,5,0"/>
                        <Button Grid.Column="1" Content="💾 Add Delivery" Command="{Binding SaveStockInCommand}" Background="#2E7D32" Foreground="White" FontWeight="Bold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="5,0,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

    </Panel>
</Window>