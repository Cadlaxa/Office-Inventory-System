<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Office_Supplies_Inventory"
        x:DataType="vm:MainViewModel"
        x:Class="Office_Supplies_Inventory.MainWindow"
        Title="Office Supplies Inventory System" Width="1150" Height="650"
        WindowStartupLocation="CenterScreen"
        Icon="/Icon/app-icon.ico"
        Background="{DynamicResource SystemControlPageBackgroundChromeLowBrush}"
        KeyDown="Window_KeyDown">
        
    <Window.Styles>
        <!-- Material You Card Style with Soft Shadow -->
        <Style Selector="Border.MaterialCard">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"/>
            <Setter Property="BoxShadow" Value="0 4 12 0 #15000000"/>
        </Style>

        <!-- Material You Button Base (Pill Shaped + Animations) -->
        <Style Selector="Button.MaterialBtn">
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="RenderTransform" Value="scale(1.0)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <!-- Smooth scaling and color fading, removed BoxShadow transition -->
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" Easing="QuadraticEaseOut"/>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- Button Hover and Press Animations -->
        <Style Selector="Button.MaterialBtn:pointerover">
            <!-- Smoothly enlarge on hover -->
            <Setter Property="RenderTransform" Value="scale(1.03)"/>
        </Style>
        <Style Selector="Button.MaterialBtn:pressed">
            <!-- Smoothly shrink when clicked -->
            <Setter Property="RenderTransform" Value="scale(0.96)"/>
        </Style>

        <!-- Google Material Accent Colors with Hover States -->
        <Style Selector="Button.Primary">
            <Setter Property="Background" Value="#1A73E8"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.Primary:pointerover">
            <Setter Property="Background" Value="#1557B0"/>
        </Style>

        <Style Selector="Button.Success">
            <Setter Property="Background" Value="#1E8E3E"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.Success:pointerover">
            <Setter Property="Background" Value="#145C26"/>
        </Style>

        <Style Selector="Button.Danger">
            <Setter Property="Background" Value="#D93025"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.Danger:pointerover">
            <Setter Property="Background" Value="#A51F16"/>
        </Style>

        <Style Selector="Button.Secondary">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Style>
        <Style Selector="Button.Secondary:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseMediumLowBrush}"/>
        </Style>

        <!-- Material You TextBox -->
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <!-- A subtle tint that perfectly adapts to Light/Dark mode -->
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>
        
        <!-- Smoothly darken the background on hover -->
        <Style Selector="TextBox:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseMediumLowBrush}"/>
        </Style>

        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#1A73E8"/>
            <!-- Reverts to solid background when actively typing -->
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
        </Style>
        
        <!-- Subtle Section Headers -->
        <Style Selector="TextBlock.SectionHeader">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>

        <!-- DataGrid Row Hover Animation -->
        <Style Selector="DataGridRow">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="DataGridRow:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}"/>
        </Style>

        <Style Selector="Arc.Spinner">
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <Setter Property="RenderTransform">
                <RotateTransform Angle="0"/>
            </Setter>
            <Style.Animations>
                <Animation Duration="0:0:0.8" IterationCount="Infinite">
                    <KeyFrame Cue="0%">
                        <Setter Property="RotateTransform.Angle" Value="0"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="RotateTransform.Angle" Value="360"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="Grid.DialogBackdrop">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="ZIndex" Value="100"/> 
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15" Easing="SineEaseInOut"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- Dialog Backdrop (Visible/Open State) -->
        <Style Selector="Grid.DialogBackdrop.show">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="IsHitTestVisible" Value="True"/>
            <Setter Property="Background" Value="#B2000000"/>
        </Style>

        <!-- Dialog Card (Base State & Transitions) -->
        <Style Selector="Grid.DialogBackdrop > Border.MaterialCard">
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="RenderTransform" Value="scale(0.85) translateY(20px)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15" Easing="SineEaseInOut"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" Easing="SineEaseOut"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- Dialog Card (Visible/Open State) -->
        <Style Selector="Grid.DialogBackdrop.show > Border.MaterialCard">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="RenderTransform" Value="scale(1) translateY(0px)"/>
        </Style>

        <Style Selector="Grid.TabContainer">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="RenderTransform" Value="translateY(25px)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CubicEaseOut"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="TabItem:selected Grid.TabContainer">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="RenderTransform" Value="translateY(0px)"/>
        </Style>

        <Style Selector="ToolTip">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Placement" Value="Pointer"/>
            <Setter Property="ShowDelay" Value="100"/>
            <Setter Property="ZIndex" Value="500"/>
        </Style>
    </Window.Styles>

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+D1" Command="{Binding SwitchTabCommand}" CommandParameter="0"/>
        <KeyBinding Gesture="Ctrl+D2" Command="{Binding SwitchTabCommand}" CommandParameter="1"/>
        <KeyBinding Command="{Binding OpenAddDialogCommand}" Gesture="Ctrl+N"/>
        <KeyBinding Command="{Binding HandleGlobalDeleteCommand}" Gesture="Delete"/>
    </Window.KeyBindings>

    <Panel>
        <StackPanel Orientation="Horizontal" 
                HorizontalAlignment="Right" 
                VerticalAlignment="Top" 
                Margin="0,20,20,0" 
                Spacing="12"
                ZIndex="50">
                
        <Image Source="/Icon/app-icon.ico" 
               Width="36" Height="36" 
               VerticalAlignment="Center" 
               ToolTip.Tip="Made by CvSU OJT's"/>
               
        <!-- GLOBAL SEARCH BAR -->
        <TextBox Text="{Binding SearchQuery}" 
                 Watermark="🔍 Search records..." 
                 Width="320"
                 FontSize="14"
                 Padding="16,8"
                 VerticalAlignment="Center"
                 Background="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
        </StackPanel>
                 
        <TabControl Margin="10" x:Name="MainTabs" SelectedIndex="{Binding SelectedTabIndex}">
            <!-- INVENTORY TAB -->
            <TabItem Header="📦 Supplies Inventory" FontSize="22" FontWeight="Bold" ToolTip.Tip="Supplies Inventory [Ctrl + 1]">
                <Grid Classes="TabContainer" ColumnDefinitions="*, 280" Margin="0,15,0,0">
                    
                    <!-- Rounded Container for DataGrid -->
                    <Border Grid.Column="0" Classes="MaterialCard" Margin="0,0,15,0" Padding="0" ClipToBounds="True">
                        
                        <DataGrid x:Name="InventoryGrid"
                                  ItemsSource="{Binding InventoryList}" 
                                  SelectedItem="{Binding SelectedItem}"
                                  SelectionMode="Extended"
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="True" 
                                  DoubleTapped="InventoryGrid_DoubleTapped"
                                  x:CompileBindings="False" 
                                  CanUserSortColumns="False" 
                                  CanUserResizeColumns="True"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="Transparent">
                            
                            <DataGrid.Styles>
                                <Style Selector="DataGridCell">
                                    <Setter Property="FontSize" Value="13" />
                                    <Setter Property="Padding" Value="12,10" />
                                </Style>
                                <Style Selector="DataGridColumnHeader">
                                    <Setter Property="FontSize" Value="13" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="Padding" Value="12,12" />
                                    <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </DataGrid.Styles>

                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding ItemCode}" IsReadOnly="True">
                                    <DataGridTextColumn.Header>
                                        <Border Background="#D95E25" CornerRadius="6" Padding="12,6" Margin="-4,0">
                                            <TextBlock Text="ITEM CODE" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="DESCRIPTION" Binding="{Binding Description}"/>
                                <DataGridTextColumn Header="MANUFACTURER" Binding="{Binding ManufacturerSupplier}" />
                                <DataGridTextColumn Header="AS OF" Binding="{Binding AsOfDate}" />

                                <DataGridTextColumn Binding="{Binding InitialStock}">
                                    <DataGridTextColumn.Header>
                                        <Border Background="#AF37F5" CornerRadius="6" Padding="12,6" Margin="-4,0">
                                            <TextBlock Text="IN STOCK" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                
                                <DataGridTextColumn Binding="{Binding Stock_In}" IsReadOnly="True">
                                    <DataGridTextColumn.Header>
                                        <Border Background="#1E8E3E" CornerRadius="6" Padding="12,6" Margin="-4,0">
                                            <TextBlock Text="IN" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>

                                <DataGridTextColumn Binding="{Binding Stock_Out}" IsReadOnly="True">
                                    <DataGridTextColumn.Header>
                                        <Border Background="#D93025" CornerRadius="6" Padding="12,6" Margin="-4,0">
                                            <TextBlock Text="OUT" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>

                                <DataGridTextColumn Binding="{Binding Final_Stock}" FontWeight="Bold" IsReadOnly="True">
                                    <DataGridTextColumn.Header>
                                        <Border Background="#1A73E8" CornerRadius="6" Padding="12,6" Margin="-4,0">
                                            <TextBlock Text="FINAL" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="LOCATION" Binding="{Binding Location}" />
                                <DataGridTextColumn Header="REMARKS" Binding="{Binding Remarks}" />
                                <DataGridTextColumn Header="STATUS" Binding="{Binding Status}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Sidebar Actions (Material Card) -->
                    <Border Grid.Column="1" Classes="MaterialCard">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Inventory Actions" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                
                                <TextBlock Text="Transactions" Classes="SectionHeader"/>
                                <Button Content="📥 Add Delivery (In)" Classes="MaterialBtn Success" Command="{Binding OpenStockInDialogCommand}" ToolTip.Tip="Log a new stock delivery (stock in)"/>
                                <Button Content="📤 Log Request (Out)" Classes="MaterialBtn Primary" Command="{Binding OpenStockOutDialogCommand}" ToolTip.Tip="Log a new stock request (stock out)"/>
                                
                                <Separator Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" Height="1" Margin="0,10"/>

                                <TextBlock Text="Manage Database" Classes="SectionHeader"/>
                                <Button Content="➕ Add New Item" Classes="MaterialBtn Secondary" Command="{Binding OpenAddDialogCommand}" ToolTip.Tip="Add a new inventory item [Ctrl+N]"/>
                                <Button Content="🗑️ Delete Selected" Classes="MaterialBtn Danger" 
                                        Command="{Binding OpenDeleteDialogCommand}" 
                                        CommandParameter="{Binding #InventoryGrid.SelectedItems}"
                                        ToolTip.Tip="Delete selected inventory items [Delete]"/>
                                
                                <Separator Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" Height="1" Margin="0,10"/>

                                <TextBlock Text="System Utilities" Classes="SectionHeader"/>

                                    <Grid ColumnDefinitions="*,*">
                                        <Button Grid.Column="0" 
                                                Classes="MaterialBtn Secondary" 
                                                Command="{Binding ImportDataCommand}"
                                                Margin="0,0,5,0"
                                                HorizontalContentAlignment="Center"
                                                ToolTip.Tip="Import data from xlsx file">
                                            <Panel>
                                                <!-- Default State -->
                                                <TextBlock Text="📥 Import" 
                                                        IsVisible="{Binding !IsImporting}" 
                                                        HorizontalAlignment="Center"/>
                                                
                                                <!-- Loading State -->
                                                <StackPanel Orientation="Horizontal" Spacing="16" 
                                                            IsVisible="{Binding IsImporting}" 
                                                            HorizontalAlignment="Center">
                                                    <Arc Classes="Spinner" Width="16" Height="16" StartAngle="0" SweepAngle="270" 
                                                        Stroke="{Binding $parent[Button].Foreground}" StrokeThickness="2" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Panel>
                                        </Button>

                                        <Button Grid.Column="1" 
                                                Classes="MaterialBtn Secondary" 
                                                Command="{Binding ExportDataCommand}"
                                                Margin="5,0,0,0"
                                                HorizontalContentAlignment="Center"
                                                ToolTip.Tip="Export data to xlsx file">
                                            <Panel>
                                                <!-- Default State -->
                                                <TextBlock Text="📤 Export" 
                                                        IsVisible="{Binding !IsExporting}" 
                                                        HorizontalAlignment="Center"/>
                                                
                                                <!-- Loading State -->
                                                <StackPanel Orientation="Horizontal" Spacing="16" 
                                                            IsVisible="{Binding IsExporting}" 
                                                            HorizontalAlignment="Center">
                                                    <Arc Classes="Spinner" Width="16" Height="16" StartAngle="0" SweepAngle="270" 
                                                        Stroke="{Binding $parent[Button].Foreground}" StrokeThickness="2" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Panel>
                                        </Button>
                                    </Grid>

                                <TextBlock Text="Settings" Classes="SectionHeader" Margin="0,15,0,0"/>
                                    <Grid ColumnDefinitions="*, Auto" VerticalAlignment="Center" Margin="0,5,0,0">
                                        <!-- Theme Toggle -->
                                        <ToggleSwitch x:Name="ThemeToggle" 
                                                    Grid.Column="0"
                                                    OffContent="Light Mode" OnContent="Dark Mode" 
                                                    IsChecked="False"
                                                    Checked="ThemeToggle_Toggled" Unchecked="ThemeToggle_Toggled"
                                                    ToolTip.Tip="Toggles Light or Dark Theme"/>
                                        
                                        <!-- Check for Updates Button -->
                                        <Button Grid.Column="1" 
                                                Content="🔄" 
                                                Classes="MaterialBtn Secondary"
                                                Width="60" 
                                                Click="CheckForUpdates_Click"
                                                ToolTip.Tip="Check for Updates"/>
                                    </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- TRANSACTION LOG TAB -->
            <TabItem Header="📋 Stock In/Out Log" FontSize="22" FontWeight="Bold" ToolTip.Tip="Stock In/Out Log [Ctrl + 2]">
                <Grid Classes="TabContainer" RowDefinitions="Auto, *">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,15,0,15">
                        <Button Content="🗑️ Delete Selected Logs" 
                                Classes="MaterialBtn Danger"
                                HorizontalAlignment="Left" Width="220"
                                Command="{Binding OpenDeleteLogDialogCommand}" 
                                CommandParameter="{Binding #TransactionLogGrid.SelectedItems}"
                                ToolTip.Tip="Delete selected transaction logs [Delete]"/>
                    </StackPanel>

                    <Border Grid.Row="1" Classes="MaterialCard" Padding="0" ClipToBounds="True">
                        <DataGrid x:Name="TransactionLogGrid"
                                  ItemsSource="{Binding TransactionLogs}"
                                  SelectedItem="{Binding SelectedLog}"
                                  SelectionMode="Extended"
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="False" 
                                  CellEditEnded="TransactionLogGrid_CellEditEnded"
                                  x:CompileBindings="False" 
                                  CanUserSortColumns="False" 
                                  CanUserResizeColumns="True"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="Transparent">

                            <DataGrid.Styles>
                                <Style Selector="DataGridCell">
                                    <Setter Property="FontSize" Value="13" />
                                    <Setter Property="Padding" Value="12,10" />
                                </Style>
                                <Style Selector="DataGridColumnHeader">
                                    <Setter Property="FontSize" Value="13" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="Padding" Value="12,12" />
                                    <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </DataGrid.Styles>

                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Date}" FontWeight="Bold">
                                    <DataGridTextColumn.Header>
                                        <Border Background="#1A73E8" CornerRadius="6" Padding="12,6" Margin="-4,0">
                                            <TextBlock Text="DATE" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="NAME REQUESTED" Binding="{Binding NameRequested}" />
                                <DataGridTextColumn Header="ITEM DESCRIPTION" Binding="{Binding ItemDescription}" Width="*" />
                                <DataGridTextColumn Header="QTY" Binding="{Binding Quantity}" />

                                <DataGridTextColumn Binding="{Binding TransactionType}">
                                    <DataGridTextColumn.Header>
                                        <Border Background="#D93025" CornerRadius="6" Padding="12,6" Margin="-4,0">
                                            <TextBlock Text="IN/OUT" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>

                                <DataGridTextColumn Binding="{Binding ItemCode}" IsReadOnly="True">
                                    <DataGridTextColumn.Header>
                                        <Border Background="#D95E25" CornerRadius="6" Padding="12,6" Margin="-4,0">
                                            <TextBlock Text="CODE / ITEM NO." Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </DataGridTextColumn.Header>
                                </DataGridTextColumn>
                                
                                <DataGridTextColumn Header="REMARKS" Binding="{Binding Remarks}" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- DIALOG OVERLAYS -->
        <!-- Add Item Dialog -->
        <Grid Classes="DialogBackdrop" Classes.show="{Binding IsAddDialogVisible}">
            <Border Classes="MaterialCard" Width="480" CornerRadius="24" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="0 12 32 0 #40000000">
                <StackPanel Spacing="12">
                    <TextBlock Text="Add New Supply Item" FontWeight="Bold" FontSize="22" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Item (Identifier/Code):" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding NewItemForm.ItemCode}" Watermark="e.g., 44122011-FO-T04" AcceptsReturn="False"/>
                    
                    <TextBlock Text="Item Description:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding NewItemForm.Description}" Watermark="e.g., Bond Paper (A4)"/>

                    <TextBlock Text="Manufacturer / Supplier:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding NewItemForm.ManufacturerSupplier}" Watermark="e.g., DBM PS"/>
                    
                    <Grid ColumnDefinitions="*, *" Margin="0,5,0,0">
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Initial Stock Level:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            <TextBox Text="{Binding NewItemForm.InitialStock}" Watermark="e.g., 50"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Storage Location:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            <TextBox Text="{Binding NewItemForm.Location}" Watermark="e.g., Steel Cabinet"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Remarks:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding NewItemForm.Remarks}" Watermark="Optional notes..."/>

                    <Grid ColumnDefinitions="*, *" Margin="0,20,0,0">
                        <Button Grid.Column="0" Content="Cancel" Classes="MaterialBtn Secondary" Command="{Binding CloseAddDialogCommand}" Margin="0,0,8,0" ToolTip.Tip="Cancel adding a new item"/>
                        <Button Grid.Column="1" Content="💾 Add Item" Classes="MaterialBtn Primary" Command="{Binding SaveNewItemCommand}" Margin="8,0,0,0" ToolTip.Tip="Save the new inventory item"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Edit Item Dialog -->
        <Grid Classes="DialogBackdrop" Classes.show="{Binding IsEditDialogVisible}">
            <Border Classes="MaterialCard" Width="520" CornerRadius="24" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="0 12 32 0 #40000000">
                <!-- Added a ScrollViewer just in case the screen resolution is small -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="600">
                    <StackPanel Spacing="12" Margin="4">
                        
                        <!-- Title -->
                        <TextBlock Text="{Binding EditItemForm.ItemCode, StringFormat='Editing: {0}'}" FontWeight="Bold" FontSize="22" Margin="0,0,0,10"/>
                        
                        <!-- Description -->
                        <TextBlock Text="Item Description:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBox Text="{Binding EditItemForm.Description}" Watermark="e.g., Bond Paper (A4)"/>

                        <!-- Manufacturer -->
                        <TextBlock Text="Manufacturer / Supplier:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBox Text="{Binding EditItemForm.ManufacturerSupplier}" Watermark="e.g., DBM PS"/>
                        
                        <Grid ColumnDefinitions="*, *" Margin="0,5,0,0">
                            <!-- Initial Stock (CRITICAL: Bound to InitialStockUI to use your custom error messages) -->
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Initial Stock Level:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBox Text="{Binding EditItemForm.InitialStockUI}" Watermark="e.g., 50"/>
                            </StackPanel>
                            
                            <!-- Location -->
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="Storage Location:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBox Text="{Binding EditItemForm.Location}" Watermark="e.g., Steel Cabinet"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*, *" Margin="0,5,0,0">
                            <!-- As Of Date -->
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="As Of Date:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBox Text="{Binding EditItemForm.AsOfDate}" Watermark="e.g., 2026-07-17"/>
                            </StackPanel>
                            
                            <!-- Status -->
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="Status:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBox Text="{Binding EditItemForm.Status}" Watermark="e.g., Active, Low Stock"/>
                            </StackPanel>
                        </Grid>

                        <!-- Read-Only Stock Summary Banner -->
                        <Border Background="#1A000000" CornerRadius="8" Padding="12" Margin="0,5,0,0">
                            <Grid ColumnDefinitions="*, *, *">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Stock In" FontSize="11" FontWeight="SemiBold" Foreground="#1E8E3E"/>
                                    <TextBlock Text="{Binding EditItemForm.Stock_In}" FontWeight="Bold" FontSize="16" Foreground="#1E8E3E"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Stock Out" FontSize="11" FontWeight="SemiBold" Foreground="#D93025"/>
                                    <TextBlock Text="{Binding EditItemForm.Stock_Out}" FontWeight="Bold" FontSize="16" Foreground="#D93025"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Final Stock" FontSize="11" FontWeight="SemiBold" Foreground="#1A73E8"/>
                                    <TextBlock Text="{Binding EditItemForm.Final_Stock}" FontWeight="Bold" FontSize="16" Foreground="#1A73E8"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Remarks -->
                        <TextBlock Text="Remarks:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBox Text="{Binding EditItemForm.Remarks}" Watermark="Optional notes..."/>

                        <!-- Action Buttons -->
                        <Grid ColumnDefinitions="*, *" Margin="0,20,0,0">
                            <Button Grid.Column="0" Content="Cancel" Classes="MaterialBtn Secondary" Command="{Binding CloseEditDialogCommand}" Margin="0,0,8,0" ToolTip.Tip="Cancel editing"/>
                            <Button Grid.Column="1" Content="💾 Save Changes" Classes="MaterialBtn Primary" Command="{Binding SaveEditedItemCommand}" Margin="8,0,0,0" ToolTip.Tip="Save changes to item"/>
                        </Grid>
                        
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Delete Confirmation Dialog -->
        <Grid Classes="DialogBackdrop" Classes.show="{Binding IsDeleteDialogVisible}">
            <Border Classes="MaterialCard" Width="400" CornerRadius="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="16">
                    <TextBlock Text="Confirm Deletion" FontWeight="Bold" FontSize="20" Foreground="#D93025"/>
                    <TextBlock Text="Are you sure you want to permanently delete the selected items? This action cannot be undone." 
                            TextWrapping="Wrap"/>
                    
                    <Grid ColumnDefinitions="*, *" Margin="0,10,0,0">
                        <Button Grid.Column="0" Content="Cancel" Classes="MaterialBtn Secondary" Command="{Binding CloseDeleteDialogCommand}" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="Yes, Delete" Classes="MaterialBtn Danger" Command="{Binding ConfirmDeleteCommand}" Margin="8,0,0,0" IsDefault="True"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Delete Log Confirmation Dialog -->
        <Grid Classes="DialogBackdrop" Classes.show="{Binding IsDeleteLogDialogVisible}">
            <Border Classes="MaterialCard" Width="400" CornerRadius="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="16">
                    <TextBlock Text="Delete Transaction Logs" FontWeight="Bold" FontSize="20" Foreground="#D93025"/>
                    <TextBlock Text="Are you sure you want to permanently remove these transaction logs? This cannot be undone." 
                            TextWrapping="Wrap"/>
                    
                    <Grid ColumnDefinitions="*, *" Margin="0,10,0,0">
                        <Button Grid.Column="0" Content="Cancel" Classes="MaterialBtn Secondary" Command="{Binding CloseDeleteLogDialogCommand}" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="Delete Logs" Classes="MaterialBtn Danger" Command="{Binding ConfirmDeleteLogCommand}" Margin="8,0,0,0" IsDefault="True"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Stock Out Dialog -->
        <Grid Classes="DialogBackdrop" Classes.show="{Binding IsStockOutDialogVisible}">
            <Border Classes="MaterialCard" Width="420" CornerRadius="24" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="0 12 32 0 #40000000">
                <StackPanel Spacing="12">
                    <TextBlock Text="Log Supply Request (Out)" FontWeight="Bold" FontSize="22" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Item (Code):" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <ComboBox ItemsSource="{Binding AllInventoryItems}" 
                            SelectedValue="{Binding StockOutForm.ItemCode}" 
                            SelectedValueBinding="{Binding ItemCode}"
                            HorizontalAlignment="Stretch" CornerRadius="12">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ItemCode}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    
                    <TextBlock Text="Employee Name:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding StockOutForm.NameRequested}" Watermark="e.g., Juan Dela Cruz"/>
                    
                    <TextBlock Text="Quantity:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding StockOutForm.Quantity}" Watermark="e.g., 1"/>

                    <TextBlock Text="Remarks:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding StockOutForm.Remarks}" Watermark="e.g., Received by employee"/>

                    <Grid ColumnDefinitions="*, *" Margin="0,20,0,0">
                        <Button Grid.Column="0" Content="Cancel" Classes="MaterialBtn Secondary" Command="{Binding CloseStockOutDialogCommand}" Margin="0,0,8,0" ToolTip.Tip="Cancel the stock out request"/>
                        <Button Grid.Column="1" Content="💾 Log Request" Classes="MaterialBtn Primary" Command="{Binding SaveStockOutCommand}" Margin="8,0,0,0" ToolTip.Tip="Log the stock out request"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Stock In Dialog -->
        <Grid Classes="DialogBackdrop" Classes.show="{Binding IsStockInDialogVisible}">
            <Border Classes="MaterialCard" Width="420" CornerRadius="24" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="0 12 32 0 #40000000">
                <StackPanel Spacing="12">
                    <TextBlock Text="Add Delivery (Stock In)" FontWeight="Bold" FontSize="22" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Select Item (Code):" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <ComboBox ItemsSource="{Binding AllInventoryItems}" 
                            SelectedValue="{Binding StockInForm.ItemCode}" 
                            SelectedValueBinding="{Binding ItemCode}"
                            HorizontalAlignment="Stretch" CornerRadius="12">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ItemCode}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    
                    <TextBlock Text="Supplier/Source:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding StockInForm.NameRequested}" Watermark="e.g., Office Depot"/>
                    
                    <TextBlock Text="Quantity Delivered:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding StockInForm.Quantity}" Watermark="e.g., 10"/>

                    <TextBlock Text="Remarks:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding StockInForm.Remarks}" Watermark="e.g., Monthly restocking"/>

                    <Grid ColumnDefinitions="*, *" Margin="0,20,0,0">
                        <Button Grid.Column="0" Content="Cancel" Classes="MaterialBtn Secondary" Command="{Binding CloseStockInDialogCommand}" Margin="0,0,8,0" ToolTip.Tip="Cancel the stock in request"/>
                        <Button Grid.Column="1" Content="💾 Add Delivery" Classes="MaterialBtn Success" Command="{Binding SaveStockInCommand}" Margin="8,0,0,0" ToolTip.Tip="Add the stock in delivery"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- SNACKBAR NOTIFICATION (Bottom Left) -->
        <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Margin="24,24,24,32" Padding="16,12" CornerRadius="8"
                Background="{Binding SnackbarColor}"
                IsHitTestVisible="False"
                BoxShadow="0 6 16 0 #40000000"
                Opacity="{Binding SnackbarOpacity}"
                ZIndex="200">
            <Border.Transitions>
                <Transitions>
                    <!-- Smooth fade in and out -->
                    <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="QuadraticEaseOut"/>
                </Transitions>
            </Border.Transitions>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="i" FontFamily="Consolas" FontWeight="Bold" Foreground="White" 
                           Background="#40FFFFFF" Padding="6,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding SnackbarMessage}" Foreground="White" 
                           FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Panel>
</Window>