<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Office_Supplies_Inventory"
        xmlns:local="using:Office_Supplies_Inventory" 
        x:DataType="vm:MainViewModel"
        x:Class="Office_Supplies_Inventory.MainWindow"
        Title="Office Supplies Inventory System" Width="1150" Height="650"
        WindowStartupLocation="CenterScreen"
        Icon="/Icon/app-icon.ico"
        Background="{DynamicResource SystemControlPageBackgroundChromeLowBrush}"
        KeyDown="Window_KeyDown">
    
    <Window.Resources>
        <local:StockColorConverter x:Key="StockColorConverter"/>
    </Window.Resources>
        
    <Window.Styles>
        <!-- Material You Card Style with Soft Shadow -->
        <Style Selector="Border.MaterialCard">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"/>
            <Setter Property="BoxShadow" Value="0 4 12 0 #15000000"/>
        </Style>

        <Style Selector="Border.SearchBar">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="12,0"/> 
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlBackgroundBaseBrush}"/>
            <!-- <Setter Property="BoxShadow" Value="0 4 12 0 #15000000"/> -->
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
                    <BoxShadowsTransition Property="BoxShadow" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Border.SearchBar:pointerover">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlBackgroundChromeMediumHighBrush}"/>
            <Setter Property="BoxShadow" Value="0 6 16 0 #20000000"/>
        </Style>

        <Style Selector="Border.SearchBar:focus-within">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightAccentBrush}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BoxShadow" Value="0 6 20 0 #25000000"/>
        </Style>

        <!-- Material You Button Base (Pill Shaped + Animations) -->
        <Style Selector="Button.MaterialBtn">
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="RenderTransform" Value="scale(1.0)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" Easing="QuadraticEaseOut"/>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- Button Hover and Press Animations -->
        <Style Selector="Button.MaterialBtn:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
            <Setter Property="CornerRadius" Value="18"/>
        </Style>
        <Style Selector="Button.MaterialBtn:pressed">
            <Setter Property="RenderTransform" Value="scale(0.96)"/>
            <Setter Property="CornerRadius" Value="24"/>
        </Style>

        <!-- Google Material Accent Colors with Hover States -->
        <Style Selector="Button.Primary">
            <Setter Property="Background" Value="#1A73E8"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.Primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1557B0"/>
        </Style>

        <Style Selector="Button.Success">
            <Setter Property="Background" Value="#1E8E3E"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.Success:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#145C26"/>
        </Style>

        <Style Selector="Button.Danger">
            <Setter Property="Background" Value="#D93025"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.Danger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#A51F16"/>
        </Style>

        <Style Selector="Button.Secondary">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Style>
        <Style Selector="Button.Secondary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseMediumLowBrush}"/>
        </Style>

        <!-- Material You TextBox -->
        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="TextBox:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseMediumLowBrush}"/>
        </Style>

        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#1A73E8"/>
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundAltHighBrush}"/>
        </Style>

        <Style Selector="AutoCompleteBox">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="AutoCompleteBox.TransparentSearch">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="AutoCompleteBox.TransparentSearch /template/ TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="AutoCompleteBox.TransparentSearch /template/ TextBox:pointerover">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="AutoCompleteBox.TransparentSearch /template/ TextBox:focus">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="AutoCompleteBox.TransparentSearch /template/ TextBox /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="AutoCompleteBox.TransparentSearch /template/ TextBox:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="AutoCompleteBox.TransparentSearch /template/ TextBox:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="DataGridRow">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="DataGridRow:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlHighlightListLowBrush}"/>
        </Style>

        <Style Selector="Arc.Spinner">
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <Setter Property="RenderTransform">
                <RotateTransform Angle="0"/>
            </Setter>
            <Style.Animations>
                <Animation Duration="0:0:0.8" IterationCount="Infinite">
                    <KeyFrame Cue="0%">
                        <Setter Property="RotateTransform.Angle" Value="0"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="RotateTransform.Angle" Value="360"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="Grid.DialogBackdrop">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="ZIndex" Value="100"/> 
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15" Easing="SineEaseInOut"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Grid.DialogBackdrop.show">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="IsHitTestVisible" Value="True"/>
            <Setter Property="ZIndex" Value="300"/>
            <Setter Property="Background" Value="#B2000000"/>
        </Style>

        <Style Selector="Grid.DialogBackdrop > Border.MaterialCard">
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="RenderTransform" Value="scale(0.85) translateY(20px)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15" Easing="SineEaseInOut"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" Easing="SineEaseOut"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Grid.DialogBackdrop.show > Border.MaterialCard">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="RenderTransform" Value="scale(1) translateY(0px)"/>
        </Style>

        <Style Selector="Grid.TabContainer">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="RenderTransform" Value="translateY(25px)"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CubicEaseOut"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.25" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="TabItem:selected Grid.TabContainer">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="RenderTransform" Value="translateY(0px)"/>
        </Style>

        <Style Selector="ToolTip">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Placement" Value="Pointer"/>
            <Setter Property="ShowDelay" Value="100"/>
            <Setter Property="ZIndex" Value="500"/>
        </Style>

        <!-- Custom TabItem Styling (Rounded Button Look) -->
        <Style Selector="TabItem">
            <Setter Property="CornerRadius" Value="20,20,8,8"/> 
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="15,4,4,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="RenderTransform" Value="scale(1.0)"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                    <BrushTransition Property="Foreground" Duration="0:0:0.2"/>
                    <CornerRadiusTransition Property="CornerRadius" Duration="0:0:0.1"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" Easing="QuadraticEaseOut"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- Tab Selected State (Primary Button Look) -->
        <Style Selector="TabItem:selected">
            <Setter Property="Background" Value="#1A73E8"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style Selector="TabItem:selected:pointerover">
            <Setter Property="Background" Value="#0d4b9c"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="20,20,20,20"/> 
            <Setter Property="RenderTransform" Value="scale(1.05)"/>
        </Style>

        <Style Selector="TabItem:selected:pointerover /template/ Border#PART_LayoutRoot">
            <Setter Property="Background" Value="#1A73E8"/>
        </Style>

        <Style Selector="TabItem:selected /template/ Border#PART_SelectedPipe">
            <Setter Property="IsVisible" Value="False"/>
            <Setter Property="Opacity" Value="0"/>
        </Style>
        
        <Style Selector="TabItem:pointerover /template/ Border#PART_SelectedPipe">
            <Setter Property="IsVisible" Value="False"/>
            <Setter Property="Opacity" Value="0"/>
        </Style>

        <Style Selector="TabItem /template/ Border#PART_SelectedPipe">
            <Setter Property="IsVisible" Value="False"/>
            <Setter Property="Opacity" Value="0"/>
        </Style>
    </Window.Styles>

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+D1" Command="{Binding SwitchTabCommand}" CommandParameter="0"/>
        <KeyBinding Gesture="Ctrl+D2" Command="{Binding SwitchTabCommand}" CommandParameter="1"/>
        <KeyBinding Command="{Binding OpenAddDialogCommand}" Gesture="Ctrl+N"/>
        <KeyBinding Command="{Binding OpenStockInDialogCommand}" Gesture="Ctrl+I"/>
        <KeyBinding Command="{Binding OpenStockOutDialogCommand}" Gesture="Ctrl+O"/>
        <KeyBinding Command="{Binding HandleGlobalDeleteCommand}" Gesture="Delete"/>
        <KeyBinding Command="{Binding ImportDataCommand}" Gesture="Ctrl+Shift+I" />
        <KeyBinding Command="{Binding ExportDataCommand}" Gesture="Ctrl+Shift+E"/>
    </Window.KeyBindings>

    <Grid RowDefinitions="Auto, *" DragDrop.AllowDrop="True">
        
        <!-- TOP NAVIGATION BAR -->
        <Border Grid.Row="0" Background="{DynamicResource SystemControlBackgroundAltHighBrush}" 
                BorderThickness="0,0,0,1" BorderBrush="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" 
                Padding="20,12" ZIndex="50">
            <Grid ColumnDefinitions="Auto, *, Auto">
                
                <!-- Icon and Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Image Source="/Icon/app-icon.ico" Width="40" Height="40" ToolTip.Tip="Made by CvSU OJT's"/>
                    <TextBlock Text="Office Supplies Inventory" FontWeight="Black" FontSize="18" VerticalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Column="1" 
                        Classes="SearchBar"
                        MaxWidth="500" MinWidth="500" Height="40" Margin="40,0"
                        HorizontalAlignment="Stretch" VerticalAlignment="Center"
                        ToolTip.Tip="Search any entries in Inventory or in Stock logs&#x0A;[Ctrl + L]">
                    
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal" Spacing="6">

                            <!-- Search Icon -->
                            <TextBlock Text="🔍" VerticalAlignment="Center" Margin="0,0,2,0" FontSize="13" Opacity="0.8"/>

                            <!-- The Active Filter Buttons (Tokens) -->
                            <ItemsControl ItemsSource="{Binding ActiveSearchTokens}" VerticalAlignment="Center">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="6"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Reduced CornerRadius to 4 and adjusted padding for a compact "pill" look -->
                                        <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}" 
                                                CornerRadius="4" Padding="6,2,4,2">
                                            <StackPanel Orientation="Horizontal" Spacing="2">
                                                
                                                <!-- Reduced FontSize to 11 to differentiate from the main typing text -->
                                                <TextBlock Text="{Binding Prefix}" 
                                                        Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" 
                                                        FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center"/>
                                                
                                                <TextBlock Text="{Binding Value}" 
                                                        Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" 
                                                        FontSize="11" VerticalAlignment="Center"/>
                                                
                                                <!-- Shrunk the button footprint so it doesn't warp the token height -->
                                                <Button Command="{ReflectionBinding $parent[Window].DataContext.RemoveSearchTokenCommand}"
                                                        CommandParameter="{Binding}"
                                                        Content="✕" FontSize="9" Padding="4,2" Margin="2,0,0,0" 
                                                        Background="Transparent" 
                                                        Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                        BorderThickness="0" VerticalAlignment="Center" Cursor="Hand"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- The Transparent Input Field -->
                            <AutoCompleteBox x:Name="MainSearchBox" Classes="TransparentSearch" Text="{Binding SearchQuery}"
                                            ItemsSource="{Binding SearchCommands}"
                                            MinimumPrefixLength="0"
                                            FilterMode="Contains"
                                            GotFocus="SearchBar_GotFocus"
                                            MaxDropDownHeight="250"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            MinWidth="200"
                                            FontSize="13"
                                            Watermark="Search (e.g. code:, name:, type:)..."
                                            VerticalAlignment="Center"
                                            Margin="-4,0,0,0">
                                
                                <AutoCompleteBox.KeyBindings>
                                    <KeyBinding Gesture="Enter" Command="{Binding CommitSearchTokenCommand}" />
                                </AutoCompleteBox.KeyBindings>
                                
                            </AutoCompleteBox>
                            
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="0,0,0,10" x:Name="MainTabs" SelectedIndex="{Binding SelectedTabIndex}">
            
            <!-- INVENTORY TAB -->
            <TabItem Header="Supplies Inventory" FontSize="18" FontWeight="Black" ToolTip.Tip="Supplies Inventory &#x0A;[Ctrl + 1]">
                <Grid Classes="TabContainer" ColumnDefinitions="*, Auto" Margin="0,0,0,0">
                    
                    <Border Grid.Column="0" Classes="MaterialCard" Margin="0,0,12,0" Padding="0" ClipToBounds="True">
                        <DataGrid x:Name="InventoryGrid"
                                ItemsSource="{Binding InventoryList}" 
                                SelectedItem="{Binding SelectedItem}"
                                SelectionChanged="DataGrid_SelectionChanged"
                                SelectionMode="Extended"
                                AutoGenerateColumns="False" 
                                IsReadOnly="True" 
                                DoubleTapped="InventoryGrid_DoubleTapped"
                                x:CompileBindings="False" 
                                CanUserSortColumns="True" 
                                Sorting="InventoryGrid_Sorting"
                                CanUserResizeColumns="True"
                                GridLinesVisibility="Horizontal"
                                BorderThickness="0"
                                Background="Transparent"
                                PointerPressed="InventoryGrid_PointerPressed"
                                PointerMoved="InventoryGrid_PointerMoved"
                                DragDrop.Drop="InventoryGrid_Drop"
                                DragDrop.AllowDrop="True">

                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Deselect" Click="DeselectMenuItem_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="❌" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <Separator/>

                                    <MenuItem Header="Edit Entry" Click="EditEntryMenuItem_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="✏️" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    
                                    <MenuItem Header="Delete Entry" Click="DeleteEntryMenuItem_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="🗑️" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <Separator/>

                                    <MenuItem Header="Stock In (Delivery)" Click="StockInMenuItem_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="📥" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    
                                    <MenuItem Header="Stock Out (Request)" Click="StockOutMenuItem_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="📤" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </MenuItem.Icon>
                                    </MenuItem>

                                    <Separator/>

                                    <MenuItem Header="Cut Row" Click="CutEntryMenuItem_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="✂️" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    
                                    <MenuItem x:Name="PasteMenuItem" Header="Paste Row" Click="PasteEntryMenuItem_Click" IsEnabled="False">
                                        <MenuItem.Icon>
                                            <TextBlock Text="📋" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            
                            <DataGrid.Styles>
                                <Style Selector="DataGridRow">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <MultiBinding Converter="{StaticResource StockColorConverter}" ConverterParameter="Row">
                                                <Binding Path="Final_Stock"/>
                                                <Binding Path="InitialStock"/>
                                                <Binding Path="Stock_In"/>
                                                <Binding Path="Stock_Out"/>
                                            </MultiBinding>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                <Style Selector="DataGridCell">
                                    <Setter Property="FontSize" Value="13" />
                                    <Setter Property="Padding" Value="12,10" />
                                </Style>
                                <Style Selector="DataGridColumnHeader">
                                    <Setter Property="FontSize" Value="13" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="Padding" Value="12,12,-20,12" />
                                    <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </DataGrid.Styles>

                            <DataGrid.Columns>
                                <DataGridTemplateColumn SortMemberPath="ItemCode" IsReadOnly="True" MaxWidth="250">
                                    <DataGridTemplateColumn.Header>
                                        <Border Background="#D95E25" CornerRadius="6" Padding="12,6" Margin="-4,0">
                                            <TextBlock Text="ITEM CODE" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <!-- Added Foreground and FontWeight here -->
                                            <TextBlock Text="{Binding ItemCode}" 
                                                    FontWeight="SemiBold"
                                                    TextTrimming="CharacterEllipsis" 
                                                    VerticalAlignment="Center" 
                                                    Margin="12,0"
                                                    ToolTip.Tip="{Binding ItemCode}"
                                                    ToolTip.ShowDelay="300">
                                                <TextBlock.Styles>
                                                    <Style Selector="TextBlock">
                                                        <Setter Property="Foreground" Value="#D95E25"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </Style>
                                                    <Style Selector="DataGridRow:selected TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemControlHighlightAltBaseHighBrush}"/>
                                                    </Style>
                                                </TextBlock.Styles>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn SortMemberPath="Description" Header="DESCRIPTION" MaxWidth="250">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Description}" 
                                                    TextTrimming="CharacterEllipsis" 
                                                    VerticalAlignment="Center" 
                                                    Margin="12,0"
                                                    ToolTip.Tip="{Binding Description}"
                                                    ToolTip.ShowDelay="300">
                                                <TextBlock.Styles>
                                                    <Style Selector="DataGridRow:selected TextBlock">
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemControlHighlightAltBaseHighBrush}"/>
                                                    </Style>
                                                </TextBlock.Styles>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn SortMemberPath="AsOfDate" Header="AS OF">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding AsOfDate}" 
                                                    TextTrimming="CharacterEllipsis" 
                                                    VerticalAlignment="Center" 
                                                    Margin="12,0"
                                                    ToolTip.Tip="{Binding AsOfDate}"
                                                    ToolTip.ShowDelay="300">
                                                <TextBlock.Styles>
                                                    <Style Selector="DataGridRow:selected TextBlock">
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemControlHighlightAltBaseHighBrush}"/>
                                                    </Style>
                                                </TextBlock.Styles>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn SortMemberPath="InitialStock">
                                    <DataGridTemplateColumn.Header>
                                        <Border Background="#AF37F5" CornerRadius="6" Padding="12,6" Margin="-4,0">
                                            <TextBlock Text="IN STOCK" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding InitialStock}" 
                                                    FontWeight="Bold" 
                                                    VerticalAlignment="Center"
                                                    Margin="12,0">
                                                <TextBlock.Styles>
                                                    <Style Selector="TextBlock">
                                                        <Setter Property="Foreground" Value="#AF37F5"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </Style>
                                                    <Style Selector="DataGridRow:selected TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemControlHighlightAltBaseHighBrush}"/>
                                                    </Style>
                                                </TextBlock.Styles>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <DataGridTemplateColumn SortMemberPath="Stock_In">
                                    <DataGridTemplateColumn.Header>
                                        <Border Background="#1E8E3E" CornerRadius="6" Padding="12,6" Margin="-4,0">
                                            <TextBlock Text="IN" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Stock_In}" 
                                                    TextTrimming="CharacterEllipsis"
                                                    ToolTip.Tip="{Binding Stock_In}"
                                                    ToolTip.ShowDelay="300"
                                                    FontWeight="Bold" 
                                                    VerticalAlignment="Center" 
                                                    Margin="12,0">
                                                <TextBlock.Styles>
                                                    <Style Selector="TextBlock">
                                                        <Setter Property="Foreground" Value="#107C41"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </Style>
                                                    <Style Selector="DataGridRow:selected TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemControlHighlightAltBaseHighBrush}"/>
                                                    </Style>
                                                </TextBlock.Styles>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn SortMemberPath="Stock_Out">
                                    <DataGridTemplateColumn.Header>
                                        <Border Background="#D93025" CornerRadius="6" Padding="12,6" Margin="-4,0">
                                            <TextBlock Text="OUT" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Stock_Out}" 
                                                    TextTrimming="CharacterEllipsis"
                                                    ToolTip.Tip="{Binding Stock_Out}"
                                                    ToolTip.ShowDelay="300"
                                                    FontWeight="Bold" 
                                                    VerticalAlignment="Center" 
                                                    Margin="12,0">
                                                <TextBlock.Styles>
                                                    <Style Selector="TextBlock">
                                                        <Setter Property="Foreground" Value="#D13438"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </Style>
                                                    <Style Selector="DataGridRow:selected TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemControlHighlightAltBaseHighBrush}"/>
                                                    </Style>
                                                </TextBlock.Styles>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn SortMemberPath="Final_Stock">
                                    <DataGridTemplateColumn.Header>
                                        <Border Background="#1A73E8" CornerRadius="6" Padding="12,6" Margin="-4,0">
                                            <TextBlock Text="FINAL" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="8,2" HorizontalAlignment="Left" Margin="12,0">
                                                
                                                <Border.Background>
                                                    <MultiBinding Converter="{StaticResource StockColorConverter}">
                                                        <Binding Path="Final_Stock"/>
                                                        <Binding Path="InitialStock"/>
                                                        <Binding Path="Stock_In"/>
                                                        <Binding Path="Stock_Out"/> 
                                                    </MultiBinding>
                                                </Border.Background>

                                                <TextBlock Text="{Binding Final_Stock}" 
                                                        TextTrimming="CharacterEllipsis"
                                                        ToolTip.Tip="{Binding Final_Stock}"
                                                        ToolTip.ShowDelay="300"
                                                        Foreground="White" 
                                                        FontWeight="Bold" 
                                                        VerticalAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn SortMemberPath="Location" Header="LOCATION">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Location}" 
                                                    TextTrimming="CharacterEllipsis" 
                                                    ToolTip.Tip="{Binding Location}"
                                                    ToolTip.ShowDelay="300"
                                                    VerticalAlignment="Center" 
                                                    Margin="12,0">
                                                <TextBlock.Styles>
                                                    <Style Selector="DataGridRow:selected TextBlock">
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemControlHighlightAltBaseHighBrush}"/>
                                                    </Style>
                                                </TextBlock.Styles>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn SortMemberPath="Remarks" Header="REMARKS">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Remarks}" 
                                                    TextTrimming="CharacterEllipsis" 
                                                    ToolTip.Tip="{Binding Remarks}"
                                                    ToolTip.ShowDelay="300"
                                                    VerticalAlignment="Center" 
                                                    Margin="12,0">
                                                <TextBlock.Styles>
                                                    <Style Selector="DataGridRow:selected TextBlock">
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemControlHighlightAltBaseHighBrush}"/>
                                                    </Style>
                                                </TextBlock.Styles>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn SortMemberPath="Status" Header="STATUS">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Status}" 
                                                    TextTrimming="CharacterEllipsis" 
                                                    ToolTip.Tip="{Binding Status}"
                                                    ToolTip.ShowDelay="300"
                                                    VerticalAlignment="Center" 
                                                    Margin="12,0">
                                                <TextBlock.Styles>
                                                    <Style Selector="DataGridRow:selected TextBlock">
                                                        <Setter Property="FontWeight" Value="Bold"/>

                                                        <Setter Property="Foreground" Value="{DynamicResource SystemControlHighlightAltBaseHighBrush}"/>
                                                    </Style>
                                                </TextBlock.Styles>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <!-- Sidebar Actions (Material Card) -->
                    <Border Grid.Column="1" 
                        Classes="MaterialCard" ClipToBounds="False" 
                        HorizontalAlignment="Right" 
                        Width="{Binding IsSidebarExpanded, Converter={StaticResource BoolToWidthConverter}}">

                        <Border.Transitions>
                            <Transitions>
                                <DoubleTransition Property="Width" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                            </Transitions>
                        </Border.Transitions>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden">
                            <StackPanel Spacing="8">

                                <Button Content="☰ Inventory Actions" 
                                    Command="{Binding ToggleSidebarCommand}" 
                                    HorizontalAlignment="Stretch" 
                                    Classes="MaterialBtn Secondary" 
                                    FontWeight="Bold"
                                    FontSize="20"/>
                                
                                <TextBlock Text="Transactions" Classes="SectionHeader" IsVisible="{Binding IsSidebarExpanded}"/>
                                <Button Content="📥 Add Delivery (In)" Classes="MaterialBtn Success" Command="{Binding OpenStockInDialogCommand}" ToolTip.Tip="Log a new stock delivery (stock in) &#x0A;[Ctrl+I]"/>
                                <Button Content="📤 Log Request (Out)" Classes="MaterialBtn Primary" Command="{Binding OpenStockOutDialogCommand}" ToolTip.Tip="Log a new stock request (stock out) &#x0A;[Ctrl+O]"/>
                                
                                <Separator Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" Height="1" Margin="0,8"/>

                                <TextBlock Text="Manage Database" Classes="SectionHeader" IsVisible="{Binding IsSidebarExpanded}"/>
                                <Button Content="➕ Add New Item" Classes="MaterialBtn Secondary" Command="{Binding OpenAddDialogCommand}" ToolTip.Tip="Add a new inventory item &#x0A;[Ctrl+N]"/>
                                <Button Content="🗑️ Delete Selected" Classes="MaterialBtn Danger" 
                                        Command="{Binding OpenDeleteDialogCommand}" 
                                        CommandParameter="{Binding #InventoryGrid.SelectedItems}"
                                        ToolTip.Tip="Delete selected inventory items [Delete]"/>
                                
                                <Separator Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" Height="1" Margin="0,8"/>

                                <TextBlock Text="System Utilities" Classes="SectionHeader" IsVisible="{Binding IsSidebarExpanded}"/>

                                <UniformGrid Columns="{Binding IsSidebarExpanded, Converter={StaticResource BoolToColumnsConverter}}"
                                    Rows="{Binding IsSidebarExpanded, Converter={StaticResource BoolToRowsConverter}}">

                                    <Button Classes="MaterialBtn Secondary" 
                                            Command="{Binding ImportDataCommand}" 
                                            HorizontalAlignment="Stretch" 
                                            HorizontalContentAlignment="Center" 
                                            Margin="0,0,8,0"
                                            IsVisible="{Binding IsSidebarExpanded}"
                                            IsHitTestVisible="{Binding IsSidebarExpanded}"
                                            ToolTip.Tip="Import data from xlsx file &#x0A;[Ctrl+Shift+I]">
                                        <Panel>
                                            <TextBlock Text="📥 Import" IsVisible="{Binding !IsImporting}" HorizontalAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal" Spacing="16" IsVisible="{Binding IsImporting}" HorizontalAlignment="Center">
                                                <Arc Classes="Spinner" Width="16" Height="16" StartAngle="0" SweepAngle="270" Stroke="{Binding $parent[Button].Foreground}" StrokeThickness="2" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Panel>
                                    </Button>

                                    <Button Classes="MaterialBtn Secondary" 
                                            Command="{Binding ImportDataCommand}" 
                                            HorizontalAlignment="Stretch" 
                                            HorizontalContentAlignment="Center" 
                                            Margin="0,0,0,8"
                                            IsVisible="{Binding !IsSidebarExpanded}"
                                            IsHitTestVisible="{Binding !IsSidebarExpanded}"
                                            ToolTip.Tip="Import data from xlsx file &#x0A;[Ctrl+Shift+I]">
                                        <Panel>
                                            <TextBlock Text="📥 Import" IsVisible="{Binding !IsImporting}" HorizontalAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal" Spacing="16" IsVisible="{Binding IsImporting}" HorizontalAlignment="Center">
                                                <Arc Classes="Spinner" Width="16" Height="16" StartAngle="0" SweepAngle="270" Stroke="{Binding $parent[Button].Foreground}" StrokeThickness="2" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Panel>
                                    </Button>

                                    <Button Classes="MaterialBtn Secondary" 
                                            Command="{Binding ExportDataCommand}" 
                                            HorizontalAlignment="Stretch" 
                                            HorizontalContentAlignment="Center" 
                                            ToolTip.Tip="Export data to xlsx file &#x0A;[Ctrl+Shift+I]">
                                        <Panel>
                                            <TextBlock Text="📤 Export" IsVisible="{Binding !IsExporting}" HorizontalAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal" Spacing="16" IsVisible="{Binding IsExporting}" HorizontalAlignment="Center">
                                                <Arc Classes="Spinner" Width="16" Height="16" StartAngle="0" SweepAngle="270" Stroke="{Binding $parent[Button].Foreground}" StrokeThickness="2" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Panel>
                                    </Button>
                                </UniformGrid>

                                <Separator Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" Height="1" Margin="0,8"/>

                                <TextBlock Text="Settings" Classes="SectionHeader" Margin="0,10,0,0" IsVisible="{Binding IsSidebarExpanded}"/>
                                <Grid ColumnDefinitions="*, Auto" VerticalAlignment="Center" Margin="0,5,0,0">
                                    <ToggleSwitch x:Name="ThemeToggle" Grid.Column="0" OffContent="Light Mode" OnContent="Dark Mode" IsChecked="False" Checked="ThemeToggle_Toggled" Unchecked="ThemeToggle_Toggled" ToolTip.Tip="Toggles Light or Dark Theme"/>
                                    <Button Grid.Column="1" Content="🔄" Classes="MaterialBtn Secondary" Width="60" Click="CheckForUpdates_Click" ToolTip.Tip="Check for Updates"/>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- TRANSACTION LOG TAB -->
            <TabItem Header="Stock In/Out Log" FontSize="18" FontWeight="Black" ToolTip.Tip="Stock In/Out Log &#x0A;[Ctrl + 2]">
                <Grid Classes="TabContainer" RowDefinitions="Auto, *">
                    <Grid Grid.Row="0" Margin="12,3,10,3">
                        <Button Content="🗑️ Delete Selected Logs" 
                                Classes="MaterialBtn Danger"
                                HorizontalAlignment="Right" 
                                Width="220"
                                Command="{Binding OpenDeleteLogDialogCommand}" 
                                CommandParameter="{Binding #TransactionLogGrid.SelectedItems}"
                                ToolTip.Tip="Delete selected transaction logs [Delete]"/>
                                
                    </Grid>

                    <Border Grid.Row="1" Classes="MaterialCard" Padding="0" ClipToBounds="True">
                        <DataGrid x:Name="TransactionLogGrid"
                                  ItemsSource="{Binding TransactionLogs}"
                                  SelectedItem="{Binding SelectedLog}"
                                  SelectionChanged="DataGrid_SelectionChanged"
                                  SelectionMode="Extended"
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="False" 
                                  CellEditEnded="TransactionLogGrid_CellEditEnded"
                                  x:CompileBindings="False" 
                                  CanUserSortColumns="True" 
                                  CanUserResizeColumns="True"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Background="Transparent">
                            
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Deselect" Click="DeselectMenuItem_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="❌" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Go to Item" Click="GotoItemMenuItem_Click">
                                        <MenuItem.Icon>
                                            <TextBlock Text="➡️" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </DataGrid.ContextMenu>

                            <DataGrid.Styles>
                                <Style Selector="DataGridCell">
                                    <Setter Property="FontSize" Value="13" />
                                    <Setter Property="Padding" Value="12,10" />
                                </Style>
                                <Style Selector="DataGridColumnHeader">
                                    <Setter Property="FontSize" Value="13" />
                                    <Setter Property="FontWeight" Value="Bold" />
                                    <Setter Property="Padding" Value="12,12,-20,12" />
                                    <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </DataGrid.Styles>

                            <DataGrid.Columns>
                                <DataGridTemplateColumn SortMemberPath="Date">
                                    <DataGridTemplateColumn.Header>
                                        <Border Background="#1A73E8" CornerRadius="6" Padding="12,6" Margin="-4,0">
                                            <TextBlock Text="DATE" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Date}" 
                                                    FontWeight="Bold" 
                                                    TextTrimming="CharacterEllipsis" 
                                                    ToolTip.Tip="{Binding Date}"
                                                    ToolTip.ShowDelay="300"
                                                    VerticalAlignment="Center" 
                                                    Margin="12,0">
                                                <TextBlock.Styles>
                                                    <Style Selector="TextBlock">
                                                        <Setter Property="Foreground" Value="#1A73E8"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </Style>
                                                    <Style Selector="DataGridRow:selected TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemControlHighlightAltBaseHighBrush}"/>
                                                    </Style>
                                                </TextBlock.Styles>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>

                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <!-- cell text box direct edit -->
                                            <TextBox Text="{Binding Date}" VerticalAlignment="Center" Margin="4"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn SortMemberPath="NameRequested" Header="NAME REQUESTED">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding NameRequested}" 
                                                    TextTrimming="CharacterEllipsis" 
                                                    ToolTip.Tip="{Binding NameRequested}"
                                                    ToolTip.ShowDelay="300"
                                                    VerticalAlignment="Center" 
                                                    Margin="12,0">
                                                <TextBlock.Styles>
                                                    <Style Selector="DataGridRow:selected TextBlock">
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemControlHighlightAltBaseHighBrush}"/>
                                                    </Style>
                                                </TextBlock.Styles>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>

                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <!-- cell text box direct edit -->
                                            <TextBox Text="{Binding NameRequested}" VerticalAlignment="Center" Margin="4"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn SortMemberPath="ItemDescription" Header="ITEM DESCRIPTION" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ItemDescription}" 
                                                    TextTrimming="CharacterEllipsis" 
                                                    ToolTip.Tip="{Binding ItemDescription}"
                                                    ToolTip.ShowDelay="300"
                                                    VerticalAlignment="Center" 
                                                    Margin="12,0">
                                                <TextBlock.Styles>
                                                    <Style Selector="DataGridRow:selected TextBlock">
                                                        <Setter Property="FontWeight" Value="Bold"/>

                                                        <Setter Property="Foreground" Value="{DynamicResource SystemControlHighlightAltBaseHighBrush}"/>
                                                    </Style>
                                                </TextBlock.Styles>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>

                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <!-- cell text box direct edit -->
                                            <TextBox Text="{Binding ItemDescription}" VerticalAlignment="Center" Margin="4"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn SortMemberPath="Quantity">
                                    <DataGridTemplateColumn.Header>
                                        <Border Background="#1E8E3E" CornerRadius="6" Padding="12,6" Margin="-4,0">
                                            <TextBlock Text="QTY" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Quantity}" 
                                                    TextTrimming="CharacterEllipsis"
                                                    ToolTip.Tip="{Binding Quantity}"
                                                    ToolTip.ShowDelay="300"
                                                    FontWeight="Bold" 
                                                    VerticalAlignment="Center" 
                                                    Margin="12,0">
                                                <TextBlock.Styles>
                                                    <Style Selector="TextBlock">
                                                        <Setter Property="Foreground" Value="#107C41"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </Style>
                                                    <Style Selector="DataGridRow:selected TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemControlHighlightAltBaseHighBrush}"/>
                                                    </Style>
                                                </TextBlock.Styles>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>

                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <!-- cell text box direct edit -->
                                            <TextBox Text="{Binding Quantity}" VerticalAlignment="Center" Margin="4"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn SortMemberPath="TransactionType">
                                    <DataGridTemplateColumn.Header>
                                        <Border Background="#D93025" CornerRadius="6" Padding="12,6" Margin="-4,0">
                                            <TextBlock Text="IN/OUT" Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding TransactionType}" 
                                                    FontWeight="Bold"
                                                    TextTrimming="CharacterEllipsis" 
                                                    ToolTip.Tip="{Binding TransactionType}"
                                                    ToolTip.ShowDelay="300"
                                                    VerticalAlignment="Center" 
                                                    Margin="12,0">
                                                <TextBlock.Styles>
                                                    <Style Selector="TextBlock">
                                                        <Setter Property="Foreground" Value="{Binding TransactionColor}"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </Style>
                                                    <Style Selector="DataGridRow:selected TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemControlHighlightAltBaseHighBrush}"/>
                                                    </Style>
                                                </TextBlock.Styles>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn SortMemberPath="ItemCode" IsReadOnly="True">
                                    <DataGridTemplateColumn.Header>
                                        <Border Background="#D95E25" CornerRadius="6" Padding="12,6" Margin="-4,0">
                                            <TextBlock Text="CODE / ITEM NO." Foreground="White" FontWeight="Bold"/>
                                        </Border>
                                    </DataGridTemplateColumn.Header>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <!-- Added Foreground and FontWeight here -->
                                            <TextBlock Text="{Binding ItemCode}" 
                                                    FontWeight="SemiBold"
                                                    TextTrimming="CharacterEllipsis" 
                                                    ToolTip.Tip="{Binding ItemCode}"
                                                    ToolTip.ShowDelay="300"
                                                    VerticalAlignment="Center" 
                                                    Margin="12,0">
                                                <TextBlock.Styles>
                                                    <Style Selector="TextBlock">
                                                        <Setter Property="Foreground" Value="#D95E25"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </Style>
                                                    <Style Selector="DataGridRow:selected TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemControlHighlightAltBaseHighBrush}"/>
                                                    </Style>
                                                </TextBlock.Styles>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <DataGridTemplateColumn SortMemberPath="Remarks" Header="REMARKS">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Remarks}" 
                                                    TextTrimming="CharacterEllipsis" 
                                                    ToolTip.Tip="{Binding Remarks}"
                                                    ToolTip.ShowDelay="300"
                                                    VerticalAlignment="Center" 
                                                    Margin="12,0">
                                                <TextBlock.Styles>
                                                    <Style Selector="DataGridRow:selected TextBlock">
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource SystemControlHighlightAltBaseHighBrush}"/>
                                                    </Style>
                                                </TextBlock.Styles>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>

                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <!-- cell text box direct edit -->
                                            <TextBox Text="{Binding Remarks}" VerticalAlignment="Center" Margin="4"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- DIALOG OVERLAYS (Added Grid.RowSpan="2" so they cover the Top Bar) -->
        <!-- Add Item Dialog -->
        <Grid Grid.RowSpan="2" Classes="DialogBackdrop" Classes.show="{Binding IsAddDialogVisible}">
            <Border Classes="MaterialCard" Width="480" CornerRadius="24" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="0 12 32 0 #40000000">
                <StackPanel Spacing="12">
                    <TextBlock Text="Add New Supply Item" FontWeight="Bold" FontSize="22" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Item (Identifier/Code):" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding NewItemForm.ItemCode}" x:Name="AddItemCodeTextBox" Watermark="e.g., 44122011-FO-T04" AcceptsReturn="False"/>
                    
                    <TextBlock Text="Item Description:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding NewItemForm.Description}" Watermark="e.g., Bond Paper (A4)"/>

                    <Grid ColumnDefinitions="*, *" Margin="0,5,0,0">
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Initial Stock Level:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            <TextBox Text="{Binding NewItemForm.InitialStockUI}" Watermark="e.g., 50"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Storage Location:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            <TextBox Text="{Binding NewItemForm.Location}" Watermark="e.g., Steel Cabinet"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Remarks:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding NewItemForm.Remarks}" Watermark="Optional notes..."/>

                    <Grid ColumnDefinitions="*, *" Margin="0,20,0,0">
                        <Button Grid.Column="0" Content="Cancel" Classes="MaterialBtn Secondary" Command="{Binding CloseAddDialogCommand}" Margin="0,0,8,0" ToolTip.Tip="Cancel adding a new item"/>
                        <Button Grid.Column="1" Content="💾 Add Item" Classes="MaterialBtn Primary" Command="{Binding SaveNewItemCommand}" Margin="8,0,0,0" ToolTip.Tip="Save the new inventory item"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Edit Item Dialog -->
        <Grid Grid.RowSpan="2" Classes="DialogBackdrop" Classes.show="{Binding IsEditDialogVisible}">
            <Border Classes="MaterialCard" Width="520" CornerRadius="24" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="0 12 32 0 #40000000">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="600">
                    <StackPanel Spacing="12" Margin="4">
                        <TextBlock Text="{Binding EditItemForm.ItemCode, StringFormat='Editing: {0}'}" FontWeight="Bold" FontSize="22" Margin="0,0,0,10"/>

                        <TextBlock Text="Item (Identifier/Code):" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBox Text="{Binding EditItemForm.ItemCode}" x:Name="EditItemDescTextBox" Watermark="Assign an Item Code here..."/>
                        
                        <TextBlock Text="Item Description:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBox Text="{Binding EditItemForm.Description}" Watermark="e.g., Bond Paper (A4)"/>
                        
                        <Grid ColumnDefinitions="*, *" Margin="0,5,0,0">
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Initial Stock Level:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBox Text="{Binding EditItemForm.InitialStockUI}" Watermark="e.g., 50"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="Storage Location:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBox Text="{Binding EditItemForm.Location}" Watermark="e.g., Steel Cabinet"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*, *" Margin="0,5,0,0">
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="As Of Date:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBox Text="{Binding EditItemForm.AsOfDate}" Watermark="e.g., 2026-07-17"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="Status:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBox Text="{Binding EditItemForm.Status}" Watermark="e.g., Active, Low Stock"/>
                            </StackPanel>
                        </Grid>

                        <!-- Read-Only Stock Summary Banner -->
                        <Border Background="#1A000000" CornerRadius="8" Padding="12" Margin="0,5,0,0">
                            <Grid ColumnDefinitions="*, *, *">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Stock In" FontSize="11" FontWeight="SemiBold" Foreground="#1E8E3E"/>
                                    <TextBlock Text="{Binding EditItemForm.Stock_In}" FontWeight="Bold" FontSize="16" Foreground="#1E8E3E"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Stock Out" FontSize="11" FontWeight="SemiBold" Foreground="#D93025"/>
                                    <TextBlock Text="{Binding EditItemForm.Stock_Out}" FontWeight="Bold" FontSize="16" Foreground="#D93025"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Final Stock" FontSize="11" FontWeight="SemiBold" Foreground="#1A73E8"/>
                                    <TextBlock Text="{Binding EditItemForm.Final_Stock}" FontWeight="Bold" FontSize="16" Foreground="#1A73E8"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock Text="Remarks:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBox Text="{Binding EditItemForm.Remarks}" Watermark="Optional notes..."/>

                        <Grid ColumnDefinitions="*, *" Margin="0,20,0,0">
                            <Button Grid.Column="0" Content="Cancel" Classes="MaterialBtn Secondary" Command="{Binding CloseEditDialogCommand}" Margin="0,0,8,0" ToolTip.Tip="Cancel editing"/>
                            <Button Grid.Column="1" Content="💾 Save Changes" Classes="MaterialBtn Primary" Command="{Binding SaveEditedItemCommand}" Margin="8,0,0,0" ToolTip.Tip="Save changes to item"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Delete Confirmation Dialog -->
        <Grid Grid.RowSpan="2" Classes="DialogBackdrop" Classes.show="{Binding IsDeleteDialogVisible}">
            <Border Classes="MaterialCard" Width="400" CornerRadius="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="16">
                    <TextBlock Text="Confirm Deletion" FontWeight="Bold" FontSize="20" Foreground="#D93025"/>
                    <TextBlock Text="Are you sure you want to permanently delete the selected items? This action cannot be undone." TextWrapping="Wrap"/>
                    <Grid ColumnDefinitions="*, *" Margin="0,10,0,0">
                        <Button Grid.Column="0" Content="Cancel" Classes="MaterialBtn Secondary" Command="{Binding CloseDeleteDialogCommand}" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="Yes, Delete" Classes="MaterialBtn Danger" Command="{Binding ConfirmDeleteCommand}" Margin="8,0,0,0" IsDefault="True"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Delete Log Confirmation Dialog -->
        <Grid Grid.RowSpan="2" Classes="DialogBackdrop" Classes.show="{Binding IsDeleteLogDialogVisible}">
            <Border Classes="MaterialCard" Width="400" CornerRadius="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="16">
                    <TextBlock Text="Delete Transaction Logs" FontWeight="Bold" FontSize="20" Foreground="#D93025"/>
                    <TextBlock Text="Are you sure you want to permanently remove these transaction logs? This cannot be undone." TextWrapping="Wrap"/>
                    <Grid ColumnDefinitions="*, *" Margin="0,10,0,0">
                        <Button Grid.Column="0" Content="Cancel" Classes="MaterialBtn Secondary" Command="{Binding CloseDeleteLogDialogCommand}" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="Delete Logs" Classes="MaterialBtn Danger" Command="{Binding ConfirmDeleteLogCommand}" Margin="8,0,0,0" IsDefault="True"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Export Complete Confirmation Dialog -->
        <Grid Grid.RowSpan="2" Classes="DialogBackdrop" Classes.show="{Binding IsExportCompleteDialogVisible}">
            <Border Classes="MaterialCard" Width="400" CornerRadius="24" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="16">
                    <!-- Excel-style Green color for success -->
                    <TextBlock Text="Export Successful" FontWeight="Bold" FontSize="20" Foreground="#107C41"/>
                    <TextBlock Text="Your inventory data has been successfully exported. Would you like to open the file now?" TextWrapping="Wrap"/>
                    
                    <Grid ColumnDefinitions="*, *" Margin="0,10,0,0">
                        <Button Grid.Column="0" 
                                Content="Close" 
                                Classes="MaterialBtn Secondary" 
                                Command="{Binding CloseExportDialogCommand}" 
                                Margin="0,0,8,0"/>
                        
                        <Button Grid.Column="1" 
                                Content="Open File" 
                                Classes="MaterialBtn Primary" 
                                Command="{Binding OpenExportedFileCommand}" 
                                Margin="8,0,0,0" 
                                IsDefault="True"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- dnd modal -->
        <Grid x:Name="DragDropOverlay" Classes="DialogBackdrop" Grid.RowSpan="2" ZIndex="1000" IsVisible="False" IsHitTestVisible="False">
            <Border Classes="MaterialCard" 
                    Width="400" 
                    Padding="0,40"
                    CornerRadius="24" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center">
                <StackPanel Spacing="16">
                    <TextBlock Text="📂" 
                            FontSize="64" 
                            HorizontalAlignment="Center"/>
                    <TextBlock Text="Drop Excel File Here" 
                            FontWeight="Bold" 
                            FontSize="20" 
                            HorizontalAlignment="Center"/>
                    <TextBlock Text="Supported formats: .xlsx and .xlsm" 
                            TextWrapping="Wrap" 
                            HorizontalAlignment="Center" 
                            Opacity="0.7"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Stock Out Dialog -->
        <Grid Grid.RowSpan="2" Classes="DialogBackdrop" Classes.show="{Binding IsStockOutDialogVisible}">
            <Border Classes="MaterialCard" Width="420" CornerRadius="24" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="0 12 32 0 #40000000">
                <StackPanel Spacing="12">
                    <TextBlock Text="Log Supply Request (Out)" FontWeight="Bold" FontSize="22" Margin="0,0,0,10"/>
                    <TextBlock Text="Item (Code):" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <ComboBox ItemsSource="{Binding AllInventoryItems}" 
                            SelectedValue="{Binding StockOutForm.ItemCode}" 
                            SelectedValueBinding="{Binding ItemCode}"
                            HorizontalAlignment="Stretch" CornerRadius="12">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ItemCode}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Item Description:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding StockOutForm.ItemDescription}" Watermark="Description..." Classes="MaterialTextBox"/>
                    
                    <TextBlock Text="Employee Name:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding StockOutForm.NameRequested}" x:Name="StockOutComboBox" Watermark="e.g., Juan Dela Cruz"/>
                    
                    <TextBlock Text="Quantity:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding StockOutForm.QuantityUI}" Watermark="e.g., 1"/>

                    <TextBlock Text="Remarks:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding StockOutForm.Remarks}" Watermark="e.g., Received by employee"/>

                    <Grid ColumnDefinitions="*, *" Margin="0,20,0,0">
                        <Button Grid.Column="0" Content="Cancel" Classes="MaterialBtn Secondary" Command="{Binding CloseStockOutDialogCommand}" Margin="0,0,8,0" ToolTip.Tip="Cancel the stock out request"/>
                        <Button Grid.Column="1" Content="💾 Log Request" Classes="MaterialBtn Primary" Command="{Binding SaveStockOutCommand}" Margin="8,0,0,0" ToolTip.Tip="Log the stock out request"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Stock In Dialog -->
        <Grid Grid.RowSpan="2" Classes="DialogBackdrop" Classes.show="{Binding IsStockInDialogVisible}">
            <Border Classes="MaterialCard" Width="420" CornerRadius="24" HorizontalAlignment="Center" VerticalAlignment="Center" BoxShadow="0 12 32 0 #40000000">
                <StackPanel Spacing="12">
                    <TextBlock Text="Add Delivery (Stock In)" FontWeight="Bold" FontSize="22" Margin="0,0,0,10"/>
                    <TextBlock Text="Select Item (Code):" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <ComboBox ItemsSource="{Binding AllInventoryItems}" 
                            SelectedValue="{Binding StockInForm.ItemCode}" 
                            SelectedValueBinding="{Binding ItemCode}"
                            HorizontalAlignment="Stretch" CornerRadius="12">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ItemCode}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="Item Description:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding StockInForm.ItemDescription}" Watermark="Description..." Classes="MaterialTextBox"/>

                    <TextBlock Text="Supplier/Source:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding StockInForm.NameRequested}" x:Name="StockInComboBox" Watermark="e.g., Office Depot"/>
                    
                    <TextBlock Text="Quantity Delivered:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding StockInForm.QuantityUI}" Watermark="e.g., 10"/>

                    <TextBlock Text="Remarks:" FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    <TextBox Text="{Binding StockInForm.Remarks}" Watermark="e.g., Monthly restocking"/>

                    <Grid ColumnDefinitions="*, *" Margin="0,20,0,0">
                        <Button Grid.Column="0" Content="Cancel" Classes="MaterialBtn Secondary" Command="{Binding CloseStockInDialogCommand}" Margin="0,0,8,0" ToolTip.Tip="Cancel the stock in request"/>
                        <Button Grid.Column="1" Content="💾 Add Delivery" Classes="MaterialBtn Success" Command="{Binding SaveStockInCommand}" Margin="8,0,0,0" ToolTip.Tip="Add the stock in delivery"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- SNACKBAR NOTIFICATION (Bottom Left) -->
        <Border Grid.RowSpan="2" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Margin="24,24,24,32" Padding="16,12" CornerRadius="8"
                Background="{Binding SnackbarColor}"
                IsHitTestVisible="False"
                BoxShadow="0 6 16 0 #40000000"
                Opacity="{Binding SnackbarOpacity}"
                ZIndex="400">
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="QuadraticEaseOut"/>
                </Transitions>
            </Border.Transitions>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="i" FontFamily="Consolas" FontWeight="Bold" Foreground="White" 
                           Background="#40FFFFFF" Padding="6,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding SnackbarMessage}" Foreground="White" 
                           FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ITEM SELECTION SNACKBAR (Top Right) -->
        <Border Grid.RowSpan="2" HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,70,12,24" Padding="10,10" CornerRadius="8"
                Background="{Binding SelectionSnackbarColor}"
                IsHitTestVisible="False"
                BoxShadow="0 6 16 0 #40000000"
                Opacity="{Binding SelectionSnackbarOpacity}"
                ZIndex="400">
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="QuadraticEaseOut"/>
                </Transitions>
            </Border.Transitions>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="📌" FontSize="16" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding SelectionSnackbarMessage}" Foreground="White" 
                        FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>