<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="400" Height="220"
        x:Class="Office_Supplies_Inventory.SplashWindow"
        Title="Loading..."
        Icon="/Icon/app-icon.ico"
        CanResize="False"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        ExtendClientAreaToDecorationsHint="True"
        SystemDecorations="BorderOnly"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="Image.SplashIcon">
            <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
            
            <Setter Property="RenderTransform">
                <ScaleTransform ScaleX="0.6" ScaleY="0.6"/>
            </Setter>
            
            <Style.Animations>
                <Animation Duration="0:0:0.6" FillMode="Forward" IterationCount="1">
                    
                    <KeyFrame Cue="0%">
                        <Setter Property="ScaleTransform.ScaleX" Value="0.6"/>
                        <Setter Property="ScaleTransform.ScaleY" Value="0.6"/>
                    </KeyFrame>
                    <!-- Overshoot pop to 110% -->
                    <KeyFrame Cue="65%">
                        <Setter Property="ScaleTransform.ScaleX" Value="1.1"/>
                        <Setter Property="ScaleTransform.ScaleY" Value="1.1"/>
                    </KeyFrame>
                    <!-- Settle cleanly at 100% -->
                    <KeyFrame Cue="100%">
                        <Setter Property="ScaleTransform.ScaleX" Value="1.0"/>
                        <Setter Property="ScaleTransform.ScaleY" Value="1.0"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </Window.Styles>
    
    <Grid RowDefinitions="*,Auto,Auto,Auto,*">
        
        <Image Grid.Row="1" Classes="SplashIcon" Margin="15" Width="110" Height="110"
               VerticalAlignment="Top" HorizontalAlignment="Center"
               Source="/Icon/app-icon.png"/>
               
        <TextBlock Grid.Row="2" Text="Office Supplies Inventory"
                   FontSize="20" FontWeight="Black"
                   HorizontalAlignment="Center" Margin="0,10,0,5"/>
                   
        <TextBlock Grid.Row="3" Text="Loading database..."
                   FontSize="12" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>
                   
        <ProgressBar Grid.Row="4" VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                     IsIndeterminate="True"/>
    </Grid>
</Window>